import "../../desktop/assets/fonts/LilexNerdFontMono-Regular.ttf";
import "../../desktop/assets/fonts/LilexNerdFontMono-Medium.ttf";
import "../../desktop/assets/fonts/LilexNerdFontMono-Bold.ttf";
import "../../desktop/assets/fonts/LilexNerdFontMono-Italic.ttf";
import "../../desktop/assets/fonts/LilexNerdFontMono-MediumItalic.ttf";
import "../../desktop/assets/fonts/LilexNerdFontMono-BoldItalic.ttf";

import {
    AoButton,
    AoAssetIconButton,
    AoCheckbox,
    AoInspectorCheckRow,
    AoInspectorCommitRow,
    AoIconButton,
    AoInspectorFileRow,
    AoInspectorModeButton,
    AoInspectorSectionRow,
    AoMenu,
    AoModalCard,
    AoProjectRow,
    AoResourceIndicator,
    AoSectionLabel,
    AoSegmentedControl,
    AoSidebarProjectTreeRow,
    AoSidebarTaskTreeRow,
    AoSplitButton,
    AoStateCard,
    AoStatusPill,
    AoTabChip,
    AoTaskRow,
    AoTextInput,
    AoToast,
    MenuEntry,
    ProjectSidebarEntry,
    RightInspectorRow,
    SegmentEntry,
    SidebarTreeEntry,
    TaskSidebarEntry,
    TerminalTabChip,
} from "components.slint";

import {
    SettingsAgentRow,
    SettingsGeneralRow,
    SettingsGitActionPanel,
    SettingsMcpRow,
    SettingsNavEntry,
    SettingsOpenInRow,
    SettingsShortcutRow,
    SettingsView,
} from "settings.slint";

export struct TerminalTextRun {
    line: int,
    column: int,
    cell-count: int,
    text: string,
    color: color,
    bold: bool,
}

export struct TerminalBackgroundSpan {
    line: int,
    column: int,
    cell-count: int,
    color: color,
}

export struct TerminalCursorSpan {
    line: int,
    column: int,
    cell-count: int,
    shape: string,
    color: color,
}

export struct TerminalLinkSpan {
    line: int,
    column: int,
    cell-count: int,
    uri: string,
}

export struct TerminalSelectionSpan {
    line: int,
    column: int,
    cell-count: int,
}

export component AppWindow inherits Window {
    in property <color> chrome_bg;
    in property <color> card_bg;
    in property <color> sunken_bg;
    in property <color> terminal_bg;
    in property <color> overlay_hover;
    in property <color> overlay_active;
    in property <color> sidebar_active_bg;
    in property <color> sidebar_active_border;
    in property <color> sidebar_icon_color;
    in property <color> border_color;
    in property <color> divider_color;
    in property <color> focus_ring;
    in property <color> text_primary;
    in property <color> text_secondary;
    in property <color> text_muted;
    in property <color> success_color;
    in property <color> warning_color;
    in property <color> danger_color;

    in-out property <bool> modal_open: false;
    in-out property <bool> left_sidebar_open: true;
    in-out property <bool> right_inspector_open: true;
    in-out property <bool> resource_popover_open: false;
    in-out property <string> terminal_status: "terminal: waiting for daemon-sandbox ticket";
    in-out property <string> active_project_name: "another-one";
    in-out property <string> active_task_name: "Slint migration";
    in-out property <string> active_branch_name: "slint-daemon-poc-clean";
    in-out property <string> active_worktree_name: "mellow-river-guides-wt";
    in-out property <string> active_project_path: "~/.another-one/worktrees/another-one/mellow-river-guides-wt";
    in-out property <string> terminal_panel_state: "ready";
    in-out property <string> terminal_panel_title: "";
    in-out property <string> terminal_panel_body: "";
    in-out property <string> terminal_panel_project: "";
    in-out property <string> terminal_panel_branch: "";
    in-out property <string> terminal_panel_task: "";
    in-out property <string> terminal_panel_tab: "";
    in-out property <string> terminal_panel_cwd: "";
    in-out property <string> terminal_error_details: "";
    in-out property <string> project_summary: "loading projects from daemon";
    in-out property <string> resource_summary: "app 1.0% / 175 MB";
    in-out property <string> right_inspector_mode: "changes";
    in-out property <string> right_inspector_state: "loading";
    in-out property <string> right_inspector_title: "Loading changes";
    in-out property <string> right_inspector_summary: "Requesting working-tree state from daemon.";
    in-out property <string> right_inspector_detail: "";
    in-out property <bool> right_inspector_compare_available: false;
    in-out property <string> right_inspector_compare_target: "";
    in-out property <bool> inspector_discard_confirm_open: false;
    in-out property <string> inspector_discard_path: "";
    in-out property <string> inspector_discard_original_path: "";
    in-out property <bool> inspector_discard_untracked: false;
    in-out property <string> appearance_label: "dark";
    in-out property <string> platform_label: "linux / keyboard";
    in-out property <string> new_task_name: "";
    in-out property <string> new_task_branch: "";
    in-out property <string> new_task_project_id: "";
    in-out property <string> toast_kind: "info";
    in-out property <string> toast_message: "";
    in-out property <string> toast_detail: "";
    in-out property <bool> settings_open: false;
    in-out property <string> settings_active_section: "general";
    in-out property <bool> component_fixture_mode: false;
    in-out property <bool> fixture_checkbox_checked: true;

    in property <[ProjectSidebarEntry]> project_rows;
    in property <[SidebarTreeEntry]> sidebar_rows;
    in property <[MenuEntry]> fixture_menu_entries;
    in property <[SegmentEntry]> fixture_segments;
    in property <[TaskSidebarEntry]> task_rows;
    in property <[TerminalTabChip]> tab_chips;
    in property <[RightInspectorRow]> right_inspector_rows;
    in property <[TerminalTextRun]> terminal_runs;
    in property <[TerminalBackgroundSpan]> terminal_background_spans;
    in property <[TerminalCursorSpan]> terminal_cursor_spans;
    in property <[TerminalLinkSpan]> terminal_link_spans;
    in property <[TerminalSelectionSpan]> terminal_selection_spans;
    in property <[SettingsNavEntry]> settings_nav_entries;
    in property <[SettingsGeneralRow]> settings_general_rows;
    in property <[SettingsAgentRow]> settings_agent_rows;
    in property <[SettingsOpenInRow]> settings_open_in_rows;
    in property <[SettingsGitActionPanel]> settings_git_action_panels;
    in property <[SettingsShortcutRow]> settings_shortcut_rows;
    in property <[SettingsMcpRow]> settings_mcp_rows;

    callback close_requested();
    callback project_selected(string);
    callback task_selected(string);
    callback tab_selected(string);
    callback tab_close_requested(string);
    callback tab_pin_toggled(string);
    callback terminal_add_tab_requested();
    callback terminal_error_copy_requested();
    callback right_inspector_mode_selected(string);
    callback inspector_stage_file_requested(string, string, bool);
    callback inspector_unstage_file_requested(string, string, bool);
    callback inspector_discard_file_requested(string, string, bool);
    callback inspector_commit_toggled(string, string);
    callback inspector_check_open_requested(string);
    callback inspector_section_toggled(string);
    callback inspector_stage_all_requested();
    callback inspector_unstage_all_requested();
    callback terminal_key(string, bool, bool, bool);
    callback terminal_focus_changed(bool);
    callback terminal_pointer_event(string, string, int, int, bool, bool, bool);
    callback terminal_resized(int, int);
    callback submit_new_task(string, string, string);
    callback toast_dismissed();
    callback toast_copy_requested();
    callback settings_nav_selected(string);
    callback settings_toggle_requested(string, string, bool);
    callback settings_action_requested(string, string);

    title: "AnotherOne";
    preferred-width: 1380px;
    preferred-height: 860px;
    background: terminal_bg;

    property <bool> mobile-layout: root.width < 760px;
    property <bool> tablet-layout: root.width >= 760px && root.width < 1180px;
    property <string> layout_label: mobile-layout ? "mobile" : tablet-layout ? "tablet" : "desktop";
    property <length> titlebar-height: mobile-layout ? 52px : 42px;
    property <length> footer-height: mobile-layout ? 0px : 38px;
    property <length> gutter-width: mobile-layout ? 0px : 4px;
    property <length> sidebar-open-width: tablet-layout ? 252px : 282px;
    property <length> sidebar-width: mobile-layout ? 0px : left_sidebar_open ? sidebar-open-width : 4px;
    property <bool> right-rail-available: !mobile-layout && root.width >= 1180px;
    property <length> right-width: right-rail-available ? right_inspector_open && root.width >= 1280px ? 464px : 4px : 0px;
    property <length> body-top: titlebar-height;
    property <length> body-height: root.height - titlebar-height - footer-height;

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: terminal_bg;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: root.titlebar-height;
            background: chrome_bg;

            AoAssetIconButton {
                x: 10px;
                y: 6px;
                width: 30px;
                icon-source: @image-url("../../desktop/assets/icons/icons__panel-left.svg");
                control-label: "Toggle project drawer";
                active: root.left_sidebar_open;
                bg: overlay_active;
                hover-bg: overlay_hover;
                border: border_color;
                icon-color: text_secondary;
                clicked => {
                    root.left_sidebar_open = !root.left_sidebar_open;
                }
            }

            Text {
                x: 52px;
                y: 10px;
                text: active_project_name;
                color: text_primary;
                font-family: "Lilex Nerd Font Mono";
                font-size: 13px;
                font-weight: 700;
            }

            Text {
                x: 52px;
                y: 25px;
                text: active_task_name;
                color: text_muted;
                font-family: "Lilex Nerd Font Mono";
                font-size: 10px;
            }

            if !root.mobile-layout: AoStatusPill {
                x: parent.width - 720px;
                y: 7px;
                width: 190px;
                label: active_branch_name;
                bg: #7d333f;
                border: #b95666;
                text-color: text_primary;
            }

            if !root.mobile-layout: AoSplitButton {
                x: parent.width - 520px;
                y: 6px;
                width: 138px;
                label: "Actions";
                control-label: "Run task action";
                menu-control-label: "Open task action menu";
                active: true;
                bg: overlay_active;
                hover-bg: overlay_hover;
                border: border_color;
                text-color: text_primary;
            }

            if !root.mobile-layout: AoButton {
                x: parent.width - 374px;
                y: 6px;
                width: 120px;
                label: "Open In";
                active: false;
                bg: overlay_active;
                hover-bg: overlay_hover;
                border: border_color;
                text-color: text_secondary;
            }

            if !root.mobile-layout: AoResourceIndicator {
                x: parent.width - 244px;
                y: 7px;
                width: 184px;
                label: resource_summary;
                bg: sunken_bg;
                border: border_color;
                text-color: text_secondary;
                warning-color: warning_color;
                danger-color: danger_color;
                active: root.resource_popover_open;
            }

            if !root.mobile-layout: TouchArea {
                x: parent.width - 244px;
                y: 7px;
                width: 184px;
                height: 24px;
                clicked => {
                    root.resource_popover_open = !root.resource_popover_open;
                }
            }

            AoAssetIconButton {
                x: parent.width - 50px;
                y: 6px;
                width: 32px;
                icon-source: @image-url("../../desktop/assets/icons/icons__close.svg");
                control-label: "Close window";
                active: false;
                bg: overlay_active;
                hover-bg: overlay_hover;
                border: border_color;
                icon-color: text_secondary;
                clicked => {
                    root.close_requested();
                }
            }
        }

        if !root.mobile-layout && root.left_sidebar_open: Rectangle {
            x: 0px;
            y: body-top;
            width: sidebar-width;
            height: body-height;
            background: chrome_bg;
            clip: true;

            AoSectionLabel {
                x: 16px;
                y: 16px;
                text: "PROJECTS";
                label-color: text_muted;
            }

            Text {
                x: parent.width - 114px;
                y: 16px;
                width: 94px;
                horizontal-alignment: right;
                text: project_summary;
                color: text_muted;
                font-family: "Lilex Nerd Font Mono";
                font-size: 10px;
            }

            if root.sidebar_rows.length == 0: Text {
                x: 16px;
                y: 54px;
                width: parent.width - 32px;
                text: "Click + to add a project";
                color: text_muted;
                font-family: "Lilex Nerd Font Mono";
                font-size: 11px;
            }

            for row[index] in root.sidebar_rows: Rectangle {
                x: 0px;
                y: row.row-y * 1px;
                width: parent.width;
                height: row.row-height * 1px;

                if row.kind == "project": AoSidebarProjectTreeRow {
                    x: 4px;
                    y: 0px;
                    width: parent.width - 8px;
                    entry: row;
                    overlay-hover: root.overlay_hover;
                    overlay-active: root.sidebar_active_bg;
                    active-border: root.sidebar_active_border;
                    icon-color: root.sidebar_icon_color;
                    text-primary: root.text_primary;
                    text-muted: root.text_muted;
                    focus-ring: root.focus_ring;
                    danger-color: root.danger_color;
                    warning-color: root.warning_color;
                    clicked(project-id) => {
                        root.project_selected(project-id);
                    }
                    add-clicked(project-id) => {
                        root.new_task_project_id = project-id;
                        root.modal_open = true;
                    }
                }

                if row.kind == "task": AoSidebarTaskTreeRow {
                    x: 14px;
                    y: 0px;
                    width: parent.width - 18px;
                    entry: row;
                    overlay-hover: root.overlay_hover;
                    overlay-active: root.sidebar_active_bg;
                    active-border: root.sidebar_active_border;
                    icon-color: root.sidebar_icon_color;
                    text-primary: root.text_primary;
                    text-secondary: root.text_secondary;
                    text-muted: root.text_muted;
                    success-color: root.success_color;
                    row-border-color: root.border_color;
                    focus-ring: root.focus_ring;
                    danger-color: root.danger_color;
                    warning-color: root.warning_color;
                    clicked(task-id) => {
                        root.task_selected(task-id);
                    }
                }
            }
        }

        if !root.mobile-layout && !root.left_sidebar_open: Rectangle {
            x: 0px;
            y: body-top;
            width: sidebar-width;
            height: body-height;
            background: chrome_bg;

            Rectangle {
                x: parent.width - 1px;
                y: 0px;
                width: 1px;
                height: parent.height;
                background: divider_color;
            }
        }

        if !root.mobile-layout: Rectangle {
            x: sidebar-width;
            y: body-top;
            width: gutter-width;
            height: body-height;
            background: #0000001f;

            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => {
                    root.left_sidebar_open = !root.left_sidebar_open;
                }
            }
        }

        terminal_surface := Rectangle {
            x: root.mobile-layout ? 0px : sidebar-width + gutter-width;
            y: body-top;
            width: root.mobile-layout ? parent.width : max(200px, parent.width - sidebar-width - right-width - gutter-width * 2);
            height: body-height;
            background: #1e1f22;
            clip: true;
            property <length> terminal-left: root.mobile-layout ? 12px : 24px;
            property <length> terminal-top: root.mobile-layout ? 132px : 76px;
            property <length> terminal-cell-width: 8px;
            property <length> terminal-cell-height: 16px;
            property <int> terminal-cols: max(20, floor((self.width - terminal-left - 24px) / terminal-cell-width));
            property <int> terminal-rows: max(8, floor((self.height - terminal-top - 16px) / terminal-cell-height));
            changed terminal-cols => {
                root.terminal_resized(self.terminal-cols, self.terminal-rows);
            }
            changed terminal-rows => {
                root.terminal_resized(self.terminal-cols, self.terminal-rows);
            }

            Rectangle {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: 36px;
                background: #27292e;
                border-width: 0px;

                for tab[index] in root.tab_chips: AoTabChip {
                    x: 12px + index * 154px;
                    y: 3px;
                    width: 146px;
                    tab: tab;
                    overlay-hover: root.overlay_hover;
                    overlay-active: root.overlay_active;
                    text-primary: root.text_primary;
                    text-muted: root.text_muted;
                    success-color: root.success_color;
                    clicked(tab-id) => {
                        root.tab_selected(tab-id);
                    }
                    close-clicked(tab-id) => {
                        root.tab_close_requested(tab-id);
                    }
                    pin-clicked(tab-id) => {
                        root.tab_pin_toggled(tab-id);
                    }
                }

                AoAssetIconButton {
                    x: parent.width - 42px;
                    y: 4px;
                    width: 28px;
                    height: 28px;
                    icon-source: @image-url("../../desktop/assets/icons/icons__plus.svg");
                    control-label: "Open new terminal tab";
                    active: false;
                    bg: overlay_active;
                    hover-bg: overlay_hover;
                    border: border_color;
                    icon-color: text_secondary;
                    clicked => {
                        root.terminal_add_tab_requested();
                    }
                }
            }

            Rectangle {
                x: 0px;
                y: 36px;
                width: parent.width;
                height: 1px;
                background: divider_color;
            }

            if root.mobile-layout: Rectangle {
                x: 10px;
                y: 50px;
                width: parent.width - 20px;
                height: 48px;
                border-radius: 12px;
                background: card_bg;
                border-width: 1px;
                border-color: border_color;

                Text {
                    x: 12px;
                    y: 8px;
                    width: parent.width - 24px;
                    text: active_task_name;
                    color: text_primary;
                    font-family: "Lilex Nerd Font Mono";
                    font-size: 13px;
                    font-weight: 600;
                }

                Text {
                    x: 12px;
                    y: 28px;
                    width: parent.width - 24px;
                    text: active_branch_name + " / " + active_worktree_name;
                    color: text_muted;
                    font-family: "Lilex Nerd Font Mono";
                    font-size: 11px;
                }
            }

            terminal_touch := TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => {
                    terminal_focus.focus();
                }
                pointer-event(event) => {
                    if self.mouse-x >= terminal_surface.terminal-left && self.mouse-y >= terminal_surface.terminal-top {
                        terminal_focus.focus();
                        root.terminal_pointer_event(
                            event.kind == PointerEventKind.down ? "down" : event.kind == PointerEventKind.up ? "up" : event.kind == PointerEventKind.move ? "move" : "cancel",
                            event.button == PointerEventButton.left ? "left" : event.button == PointerEventButton.middle ? "middle" : event.button == PointerEventButton.right ? "right" : "other",
                            max(0, floor((self.mouse-x - terminal_surface.terminal-left) / terminal_surface.terminal-cell-width)),
                            max(0, floor((self.mouse-y - terminal_surface.terminal-top) / terminal_surface.terminal-cell-height)),
                            event.modifiers.control,
                            event.modifiers.alt,
                            event.modifiers.shift,
                        );
                    }
                }
            }

            terminal_focus := FocusScope {
                width: 0px;
                height: 0px;
                focus-changed-event => {
                    root.terminal_focus_changed(self.has-focus);
                }
                key-pressed(event) => {
                    root.terminal_key(
                        event.text,
                        event.modifiers.control,
                        event.modifiers.alt,
                        event.modifiers.shift,
                    );
                    return accept;
                }
            }

            Text {
                x: terminal_surface.terminal-left;
                y: root.mobile-layout ? 104px : 52px;
                width: parent.width - 48px;
                text: root.terminal_status;
                color: text_secondary;
                font-family: "Lilex Nerd Font Mono";
                font-size: 12px;
            }

            if root.terminal_panel_state != "ready": Rectangle {
                x: max(24px, (parent.width - 520px) / 2);
                y: max(96px, (parent.height - 280px) / 2);
                width: min(520px, parent.width - 48px);
                height: root.terminal_panel_state == "failed" ? 286px : 238px;
                border-radius: 14px;
                border-width: 1px;
                border-color: root.terminal_panel_state == "failed" ? danger_color : border_color;
                background: #25282d;

                Image {
                    x: 24px;
                    y: 24px;
                    width: 20px;
                    height: 20px;
                    source: root.terminal_panel_state == "failed" ? @image-url("../../desktop/assets/icons/icons__alert-triangle.svg") : @image-url("../../desktop/assets/icons/icons__terminal.svg");
                    colorize: root.terminal_panel_state == "failed" ? danger_color : focus_ring;
                }

                Text {
                    x: 56px;
                    y: 22px;
                    width: parent.width - 92px;
                    text: root.terminal_panel_title;
                    color: text_primary;
                    font-family: "Lilex Nerd Font Mono";
                    font-size: 13px;
                    font-weight: 700;
                }

                if root.terminal_panel_state == "failed": AoAssetIconButton {
                    x: parent.width - 52px;
                    y: 18px;
                    width: 30px;
                    height: 28px;
                    icon-source: @image-url("../../desktop/assets/icons/icons__copy.svg");
                    control-label: "Copy terminal error details";
                    bg: overlay_active;
                    hover-bg: overlay_hover;
                    border: border_color;
                    icon-color: text_secondary;
                    clicked => {
                        root.terminal_error_copy_requested();
                    }
                }

                Text {
                    x: 24px;
                    y: 58px;
                    width: parent.width - 48px;
                    text: root.terminal_panel_body;
                    color: root.terminal_panel_state == "failed" ? danger_color : text_muted;
                    font-family: "Lilex Nerd Font Mono";
                    font-size: 12px;
                }

                Text {
                    x: 24px;
                    y: 96px;
                    width: parent.width - 48px;
                    text: "Project: " + root.terminal_panel_project;
                    color: text_muted;
                    font-family: "Lilex Nerd Font Mono";
                    font-size: 11px;
                }

                Text {
                    x: 24px;
                    y: 118px;
                    width: parent.width - 48px;
                    text: "Branch: " + root.terminal_panel_branch;
                    color: text_muted;
                    font-family: "Lilex Nerd Font Mono";
                    font-size: 11px;
                }

                Text {
                    x: 24px;
                    y: 140px;
                    width: parent.width - 48px;
                    text: "Task: " + root.terminal_panel_task;
                    color: text_muted;
                    font-family: "Lilex Nerd Font Mono";
                    font-size: 11px;
                }

                Text {
                    x: 24px;
                    y: 162px;
                    width: parent.width - 48px;
                    text: "Agent/Tab: " + root.terminal_panel_tab;
                    color: text_muted;
                    font-family: "Lilex Nerd Font Mono";
                    font-size: 11px;
                }

                Text {
                    x: 24px;
                    y: 184px;
                    width: parent.width - 48px;
                    text: "CWD: " + root.terminal_panel_cwd;
                    color: text_muted;
                    font-family: "Lilex Nerd Font Mono";
                    font-size: 11px;
                }

                if root.terminal_panel_state == "failed": Text {
                    x: 24px;
                    y: 220px;
                    width: parent.width - 48px;
                    text: root.terminal_error_details;
                    color: text_muted;
                    font-family: "Lilex Nerd Font Mono";
                    font-size: 10px;
                }
            }

            for span in root.terminal_background_spans: Rectangle {
                x: terminal_surface.terminal-left + span.column * terminal_surface.terminal-cell-width;
                y: terminal_surface.terminal-top + span.line * terminal_surface.terminal-cell-height;
                width: span.cell-count * terminal_surface.terminal-cell-width;
                height: terminal_surface.terminal-cell-height;
                background: span.color;
            }

            for span in root.terminal_selection_spans: Rectangle {
                x: terminal_surface.terminal-left + span.column * terminal_surface.terminal-cell-width;
                y: terminal_surface.terminal-top + span.line * terminal_surface.terminal-cell-height;
                width: span.cell-count * terminal_surface.terminal-cell-width;
                height: terminal_surface.terminal-cell-height;
                background: focus_ring.with-alpha(0.34);
            }

            for link in root.terminal_link_spans: Rectangle {
                x: terminal_surface.terminal-left + link.column * terminal_surface.terminal-cell-width;
                y: terminal_surface.terminal-top + (link.line + 1) * terminal_surface.terminal-cell-height - 2px;
                width: link.cell-count * terminal_surface.terminal-cell-width;
                height: 1px;
                background: focus_ring.with-alpha(0.92);
            }

            for run in root.terminal_runs: Text {
                x: terminal_surface.terminal-left + run.column * terminal_surface.terminal-cell-width;
                y: terminal_surface.terminal-top + run.line * terminal_surface.terminal-cell-height;
                text: run.text;
                color: run.color;
                font-family: "Lilex Nerd Font Mono";
                font-size: 13px;
                font-weight: run.bold ? 700 : 400;
            }

            for cursor in root.terminal_cursor_spans: Rectangle {
                x: terminal_surface.terminal-left + cursor.column * terminal_surface.terminal-cell-width;
                y: terminal_surface.terminal-top + cursor.line * terminal_surface.terminal-cell-height
                    + (cursor.shape == "underline" ? terminal_surface.terminal-cell-height - 2px : 0px);
                width: cursor.shape == "beam" ? 2px : cursor.cell-count * terminal_surface.terminal-cell-width;
                height: cursor.shape == "underline" ? 2px : terminal_surface.terminal-cell-height;
                border-width: cursor.shape == "hollow-block" ? 1px : 0px;
                border-color: cursor.color;
                background: cursor.shape == "hollow-block" ? transparent : cursor.color;
            }
        }

        if !root.mobile-layout && root.right-width > 0px: Rectangle {
            x: parent.width - right-width - gutter-width;
            y: body-top;
            width: gutter-width;
            height: body-height;
            background: #0000001f;

            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => {
                    root.right_inspector_open = !root.right_inspector_open;
                }
            }
        }

        if !root.mobile-layout && root.right-width > 0px && !root.right_inspector_open: Rectangle {
            x: parent.width - right-width;
            y: body-top;
            width: right-width;
            height: body-height;
            background: chrome_bg;

            Rectangle {
                x: 0px;
                y: 0px;
                width: 1px;
                height: parent.height;
                background: divider_color;
            }
        }

        if !root.mobile-layout && root.right-width > 8px: Rectangle {
            x: parent.width - right-width;
            y: body-top;
            width: right-width;
            height: body-height;
            background: chrome_bg;
            clip: true;

            Rectangle {
                x: 0px;
                y: 0px;
                width: 4px;
                height: parent.height;
                background: #0000001f;
            }

            AoAssetIconButton {
                x: parent.width - 44px;
                y: 10px;
                width: 28px;
                icon-source: @image-url("../../desktop/assets/icons/icons__panel-right.svg");
                control-label: "Collapse inspector";
                active: false;
                bg: overlay_active;
                hover-bg: overlay_hover;
                border: border_color;
                icon-color: text_secondary;
                clicked => {
                    root.right_inspector_open = false;
                }
            }

            Rectangle {
                x: 8px;
                y: 6px;
                width: parent.width - 58px;
                height: 38px;

                AoInspectorModeButton {
                    x: 0px;
                    y: 0px;
                    width: 92px;
                    label: "Changes";
                    icon-source: @image-url("../../desktop/assets/icons/icons__file_icons__changes.svg");
                    active: root.right_inspector_mode == "changes";
                    hover-bg: overlay_hover;
                    active-bg: #262a30;
                    border: border_color;
                    text-primary: text_primary;
                    text-muted: text_muted;
                    clicked => {
                        root.right_inspector_mode = "changes";
                        root.right_inspector_mode_selected("changes");
                    }
                }

                AoInspectorModeButton {
                    x: 98px;
                    y: 0px;
                    width: 92px;
                    label: "Commits";
                    icon-source: @image-url("../../desktop/assets/icons/icons__git-commit.svg");
                    active: root.right_inspector_mode == "commits";
                    hover-bg: overlay_hover;
                    active-bg: #262a30;
                    border: border_color;
                    text-primary: text_primary;
                    text-muted: text_muted;
                    clicked => {
                        root.right_inspector_mode = "commits";
                        root.right_inspector_mode_selected("commits");
                    }
                }

                AoInspectorModeButton {
                    x: 196px;
                    y: 0px;
                    width: 84px;
                    label: "Checks";
                    icon-source: @image-url("../../desktop/assets/icons/icons__tool-check.svg");
                    active: root.right_inspector_mode == "checks";
                    hover-bg: overlay_hover;
                    active-bg: #262a30;
                    border: border_color;
                    text-primary: text_primary;
                    text-muted: text_muted;
                    clicked => {
                        root.right_inspector_mode = "checks";
                        root.right_inspector_mode_selected("checks");
                    }
                }

                if root.right_inspector_compare_available: AoInspectorModeButton {
                    x: 286px;
                    y: 0px;
                    width: 98px;
                    label: "Compare";
                    icon-source: @image-url("../../desktop/assets/icons/icons__git-split.svg");
                    active: root.right_inspector_mode == "compare";
                    hover-bg: overlay_hover;
                    active-bg: #262a30;
                    border: border_color;
                    text-primary: text_primary;
                    text-muted: text_muted;
                    clicked => {
                        root.right_inspector_mode = "compare";
                        root.right_inspector_mode_selected("compare");
                    }
                }
            }

            Rectangle {
                x: 0px;
                y: 42px;
                width: parent.width;
                height: 1px;
                background: divider_color;
            }

            if root.right_inspector_state != "dirty": Rectangle {
                x: 18px;
                y: 84px;
                width: parent.width - 36px;
                height: 170px;
                border-radius: 12px;
                border-width: 1px;
                border-color: border_color;
                background: card_bg;

                Image {
                    x: 18px;
                    y: 18px;
                    width: 18px;
                    height: 18px;
                    source: root.right_inspector_mode == "changes" ? @image-url("../../desktop/assets/icons/icons__file_icons__changes.svg") : root.right_inspector_mode == "commits" ? @image-url("../../desktop/assets/icons/icons__git-commit.svg") : @image-url("../../desktop/assets/icons/icons__tool-check.svg");
                    colorize: root.right_inspector_state == "error" ? danger_color : text_muted;
                }

                Text {
                    x: 46px;
                    y: 18px;
                    width: parent.width - 64px;
                    text: root.right_inspector_title;
                    color: text_primary;
                    font-family: "Lilex Nerd Font Mono";
                    font-size: 13px;
                    font-weight: 700;
                }

                Text {
                    x: 18px;
                    y: 54px;
                    width: parent.width - 36px;
                    text: root.right_inspector_summary;
                    color: root.right_inspector_state == "error" ? danger_color : text_muted;
                    font-family: "Lilex Nerd Font Mono";
                    font-size: 12px;
                }

                Text {
                    x: 18px;
                    y: 96px;
                    width: parent.width - 36px;
                    text: root.right_inspector_detail;
                    color: text_muted;
                    font-family: "Lilex Nerd Font Mono";
                    font-size: 11px;
                }
            }

            if root.right_inspector_state == "dirty": Rectangle {
                x: 0px;
                y: 50px;
                width: parent.width;
                height: parent.height - 50px;
                clip: true;

                for row[index] in root.right_inspector_rows: Rectangle {
                    x: row.kind == "section" ? 0px : 4px;
                    y: row.row-y * 1px;
                    width: row.kind == "section" ? parent.width : parent.width - 8px;
                    height: row.row-height * 1px;

                    if row.kind == "section": AoInspectorSectionRow {
                        width: parent.width;
                        entry: row;
                        row-border-color: root.divider_color;
                        text-primary: root.text_primary;
                        text-muted: root.text_muted;
                        hover-bg: #ffffff08;
                        icon-color: root.text_secondary;
                        toggled(group) => {
                            root.inspector_section_toggled(group);
                        }
                        stage-all-clicked(project-id) => {
                            root.inspector_stage_all_requested();
                        }
                        unstage-all-clicked(project-id) => {
                            root.inspector_unstage_all_requested();
                        }
                    }

                    if row.kind == "file": AoInspectorFileRow {
                        width: parent.width;
                        entry: row;
                        text-primary: root.text_primary;
                        text-muted: root.text_muted;
                        hover-bg: #ffffff0a;
                        action-hover-bg: #ffffff14;
                        icon-color: root.text_secondary;
                        row-border-color: root.border_color;
                        stage-file-clicked(path, original_path, untracked) => {
                            root.inspector_stage_file_requested(path, original_path, untracked);
                        }
                        unstage-file-clicked(path, original_path, untracked) => {
                            root.inspector_unstage_file_requested(path, original_path, untracked);
                        }
                        discard-file-clicked(path, original_path, untracked) => {
                            root.inspector_discard_path = path;
                            root.inspector_discard_original_path = original_path;
                            root.inspector_discard_untracked = untracked;
                            root.inspector_discard_confirm_open = true;
                        }
                    }

                    if row.kind == "commit": AoInspectorCommitRow {
                        width: parent.width;
                        entry: row;
                        text-primary: root.text_primary;
                        text-muted: root.text_muted;
                        hover-bg: #ffffff0a;
                        toggled(project_id, commit_id) => {
                            root.inspector_commit_toggled(project_id, commit_id);
                        }
                    }

                    if row.kind == "check": AoInspectorCheckRow {
                        width: parent.width;
                        entry: row;
                        text-primary: root.text_primary;
                        text-muted: root.text_muted;
                        hover-bg: #ffffff0a;
                        action-hover-bg: #ffffff14;
                        icon-color: root.text_secondary;
                        open-requested(uri) => {
                            root.inspector_check_open_requested(uri);
                        }
                    }
                }
            }

            if root.inspector_discard_confirm_open: Rectangle {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                background: #00000080;

                scrim-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    clicked => {
                        root.inspector_discard_confirm_open = false;
                        root.inspector_discard_path = "";
                        root.inspector_discard_original_path = "";
                        root.inspector_discard_untracked = false;
                    }
                }

                Rectangle {
                    x: 22px;
                    y: 84px;
                    width: parent.width - 44px;
                    height: 232px;
                    border-radius: 14px;
                    border-width: 1px;
                    border-color: border_color;
                    background: card_bg;

                    card-touch := TouchArea {
                        width: parent.width;
                        height: parent.height;
                    }

                    Image {
                        x: 18px;
                        y: 18px;
                        width: 18px;
                        height: 18px;
                        source: @image-url("../../desktop/assets/icons/icons__discard.svg");
                        colorize: danger_color;
                    }

                    Text {
                        x: 46px;
                        y: 18px;
                        width: parent.width - 64px;
                        text: "Confirm Discard";
                        color: text_primary;
                        font-family: "Lilex Nerd Font Mono";
                        font-size: 13px;
                        font-weight: 700;
                    }

                    Text {
                        x: 18px;
                        y: 58px;
                        width: parent.width - 36px;
                        text: root.inspector_discard_untracked ? "Delete untracked file \"" + root.inspector_discard_path + "\"?" : "Discard changes to \"" + root.inspector_discard_path + "\"?";
                        color: text_primary;
                        font-family: "Lilex Nerd Font Mono";
                        font-size: 12px;
                        font-weight: 600;
                        wrap: word-wrap;
                    }

                    Text {
                        x: 18px;
                        y: 116px;
                        width: parent.width - 36px;
                        text: "This action cannot be undone.";
                        color: text_muted;
                        font-family: "Lilex Nerd Font Mono";
                        font-size: 11px;
                    }

                    AoButton {
                        x: parent.width - 196px;
                        y: parent.height - 50px;
                        width: 80px;
                        label: "Cancel";
                        control-label: "Cancel discard";
                        active: true;
                        bg: overlay_active;
                        hover-bg: overlay_hover;
                        border: border_color;
                        focus-ring: focus_ring;
                        text-color: text_secondary;
                        clicked => {
                            root.inspector_discard_confirm_open = false;
                            root.inspector_discard_path = "";
                            root.inspector_discard_original_path = "";
                            root.inspector_discard_untracked = false;
                        }
                    }

                    AoButton {
                        x: parent.width - 104px;
                        y: parent.height - 50px;
                        width: 86px;
                        label: "Discard";
                        control-label: "Confirm discard";
                        active: true;
                        destructive: true;
                        bg: #cf3030;
                        hover-bg: #d95555;
                        border: #e06b6b;
                        focus-ring: focus_ring;
                        text-color: #ffffff;
                        danger-color: #ffffff;
                        clicked => {
                            root.inspector_discard_file_requested(root.inspector_discard_path, root.inspector_discard_original_path, root.inspector_discard_untracked);
                            root.inspector_discard_confirm_open = false;
                            root.inspector_discard_path = "";
                            root.inspector_discard_original_path = "";
                            root.inspector_discard_untracked = false;
                        }
                    }
                }
            }
        }

        if !root.mobile-layout: Rectangle {
            x: 0px;
            y: parent.height - footer-height;
            width: parent.width;
            height: footer-height;
            background: chrome_bg;

            AoAssetIconButton {
                x: 10px;
                y: 6px;
                width: 32px;
                icon-source: @image-url("../../desktop/assets/icons/icons__settings.svg");
                control-label: "Open settings";
                active: false;
                bg: overlay_active;
                hover-bg: overlay_hover;
                border: border_color;
                icon-color: text_secondary;
                clicked => {
                    root.settings_open = true;
                }
            }

            AoAssetIconButton {
                x: 50px;
                y: 6px;
                width: 32px;
                icon-source: @image-url("../../desktop/assets/icons/icons__plus.svg");
                control-label: "Create task";
                active: false;
                bg: overlay_active;
                hover-bg: overlay_hover;
                border: border_color;
                icon-color: text_secondary;
                clicked => {
                    root.new_task_project_id = "";
                    root.modal_open = true;
                }
            }

            AoStatusPill {
                x: sidebar-width + gutter-width + 12px;
                y: 7px;
                width: 240px;
                label: active_branch_name;
                bg: transparent;
                border: transparent;
                text-color: text_secondary;
            }

            AoStatusPill {
                x: sidebar-width + gutter-width + 260px;
                y: 7px;
                width: 260px;
                label: active_worktree_name;
                bg: transparent;
                border: transparent;
                text-color: text_secondary;
            }

            AoStatusPill {
                x: parent.width - 380px;
                y: 7px;
                width: 122px;
                label: layout_label;
                bg: transparent;
                border: transparent;
                text-color: text_muted;
            }

            AoStatusPill {
                x: parent.width - 258px;
                y: 7px;
                width: 122px;
                label: "theme " + appearance_label;
                bg: transparent;
                border: transparent;
                text-color: text_muted;
            }

            AoStatusPill {
                x: parent.width - 136px;
                y: 7px;
                width: 122px;
                label: platform_label;
                bg: transparent;
                border: transparent;
                text-color: text_muted;
            }
        }

        if resource_popover_open && !component_fixture_mode: Rectangle {
            x: max(12px, parent.width - 372px);
            y: titlebar-height + 12px;
            width: 360px;
            height: 230px;
            border-radius: 16px;
            border-width: 1px;
            border-color: border_color;
            background: card_bg;

            Text {
                x: 18px;
                y: 16px;
                text: "RESOURCE USAGE";
                color: text_muted;
                font-family: "Lilex Nerd Font Mono";
                font-size: 11px;
                font-weight: 600;
            }

            AoStateCard {
                x: 16px;
                y: 44px;
                width: parent.width - 32px;
                title: "App shell";
                body: resource_summary;
                state: "populated";
                card-bg: terminal_bg;
                card-border-color: border_color;
                text-primary: text_primary;
                text-muted: text_muted;
                success-color: success_color;
                warning-color: warning_color;
                danger-color: danger_color;
            }

            AoStateCard {
                x: 16px;
                y: 154px;
                width: parent.width - 32px;
                title: "Terminal sessions";
                body: "Subprocess CPU/RSS is tracked separately by daemon session.";
                state: "loading";
                card-bg: terminal_bg;
                card-border-color: border_color;
                text-primary: text_primary;
                text-muted: text_muted;
                success-color: success_color;
                warning-color: warning_color;
                danger-color: danger_color;
            }
        }

        if component_fixture_mode: Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: terminal_bg;
            clip: true;

            Text {
                x: 28px;
                y: 24px;
                text: "Slint component state fixture";
                color: text_primary;
                font-family: "Lilex Nerd Font Mono";
                font-size: 20px;
                font-weight: 700;
            }

            Text {
                x: 28px;
                y: 54px;
                width: parent.width - 56px;
                text: "Deterministic review board for GPUI-equivalent controls, rows, menus, inputs, status cards, and toast surfaces.";
                color: text_muted;
                font-family: "Lilex Nerd Font Mono";
                font-size: 12px;
            }

            AoSectionLabel {
                x: 32px;
                y: 96px;
                text: "CONTROLS";
                label-color: text_muted;
            }

            AoButton {
                x: 32px;
                y: 122px;
                width: 96px;
                label: "Normal";
                bg: overlay_active;
                hover-bg: overlay_hover;
                border: border_color;
                focus-ring: focus_ring;
                text-color: text_primary;
            }

            AoButton {
                x: 140px;
                y: 122px;
                width: 96px;
                label: "Active";
                active: true;
                bg: overlay_active;
                hover-bg: overlay_hover;
                border: border_color;
                focus-ring: focus_ring;
                text-color: text_primary;
            }

            AoButton {
                x: 248px;
                y: 122px;
                width: 104px;
                label: "Loading";
                loading: true;
                bg: overlay_active;
                hover-bg: overlay_hover;
                border: border_color;
                focus-ring: focus_ring;
                text-color: text_primary;
            }

            AoButton {
                x: 364px;
                y: 122px;
                width: 118px;
                label: "Destruct";
                destructive: true;
                bg: overlay_active;
                hover-bg: overlay_hover;
                border: border_color;
                focus-ring: focus_ring;
                text-color: text_primary;
                danger-color: danger_color;
            }

            AoButton {
                x: 494px;
                y: 122px;
                width: 104px;
                label: "Disabled";
                disabled: true;
                bg: overlay_active;
                hover-bg: overlay_hover;
                border: border_color;
                focus-ring: focus_ring;
                text-color: text_primary;
            }

            AoIconButton {
                x: 620px;
                y: 122px;
                width: 32px;
                icon: "+";
                control-label: "Fixture icon normal";
                bg: overlay_active;
                hover-bg: overlay_hover;
                border: border_color;
                focus-ring: focus_ring;
                icon-color: text_secondary;
            }

            AoSplitButton {
                x: 664px;
                y: 122px;
                width: 148px;
                label: "Actions";
                active: true;
                bg: overlay_active;
                hover-bg: overlay_hover;
                border: border_color;
                focus-ring: focus_ring;
                text-color: text_primary;
            }

            AoCheckbox {
                x: 32px;
                y: 170px;
                width: 190px;
                checked <=> root.fixture_checkbox_checked;
                label: "Checked option";
                bg: overlay_active;
                hover-bg: overlay_hover;
                border: border_color;
                focus-ring: focus_ring;
                text-color: text_primary;
                danger-color: danger_color;
            }

            AoCheckbox {
                x: 240px;
                y: 170px;
                width: 190px;
                checked: false;
                label: "Validation error";
                error: true;
                bg: overlay_active;
                hover-bg: overlay_hover;
                border: border_color;
                focus-ring: focus_ring;
                text-color: text_primary;
                danger-color: danger_color;
            }

            AoSegmentedControl {
                x: 452px;
                y: 168px;
                width: 360px;
                entries: root.fixture_segments;
                bg: sunken_bg;
                hover-bg: overlay_active;
                border: border_color;
                focus-ring: focus_ring;
                text-color: text_primary;
                muted-color: text_muted;
            }

            AoSectionLabel {
                x: 32px;
                y: 224px;
                text: "PROJECT ROWS";
                label-color: text_muted;
            }

            for project[index] in root.project_rows: AoProjectRow {
                x: 28px;
                y: 248px + index * 72px;
                width: 360px;
                entry: project;
                overlay-hover: root.overlay_hover;
                overlay-active: root.overlay_active;
                text-primary: root.text_primary;
                text-secondary: root.text_secondary;
                text-muted: root.text_muted;
                focus-ring: root.focus_ring;
                danger-color: root.danger_color;
                warning-color: root.warning_color;
            }

            AoSectionLabel {
                x: 420px;
                y: 224px;
                text: "TASK ROWS";
                label-color: text_muted;
            }

            for task[index] in root.task_rows: AoTaskRow {
                x: 416px;
                y: 248px + index * 64px;
                width: 380px;
                entry: task;
                overlay-hover: root.overlay_hover;
                overlay-active: root.overlay_active;
                text-primary: root.text_primary;
                text-secondary: root.text_secondary;
                text-muted: root.text_muted;
                success-color: root.success_color;
                row-border-color: root.border_color;
                focus-ring: root.focus_ring;
                danger-color: root.danger_color;
                warning-color: root.warning_color;
            }

            AoSectionLabel {
                x: 840px;
                y: 96px;
                text: "INPUTS / CARDS";
                label-color: text_muted;
            }

            AoTextInput {
                x: 840px;
                y: 122px;
                width: 260px;
                placeholder-text: "Focused field target";
                text: "Agent launch args";
                field-bg: sunken_bg;
                field-border: border_color;
                focus-border: focus_ring;
                error-color: danger_color;
                text-color: text_primary;
                placeholder-color: text_muted;
            }

            AoTextInput {
                x: 840px;
                y: 170px;
                width: 260px;
                placeholder-text: "Validation error";
                text: "";
                field-bg: sunken_bg;
                field-border: border_color;
                focus-border: focus_ring;
                error-color: danger_color;
                text-color: text_primary;
                placeholder-color: text_muted;
                error: true;
            }

            AoStateCard {
                x: 840px;
                y: 224px;
                width: 260px;
                title: "Loading";
                body: "Waiting for daemon";
                state: "loading";
                card-bg: card_bg;
                card-border-color: border_color;
                text-primary: text_primary;
                text-muted: text_muted;
                success-color: success_color;
                warning-color: warning_color;
                danger-color: danger_color;
            }

            AoStateCard {
                x: 840px;
                y: 340px;
                width: 260px;
                title: "Error";
                body: "Transport unavailable";
                state: "error";
                card-bg: card_bg;
                card-border-color: border_color;
                text-primary: text_primary;
                text-muted: text_muted;
                success-color: success_color;
                warning-color: warning_color;
                danger-color: danger_color;
            }

            AoMenu {
                x: 840px;
                y: 468px;
                width: 260px;
                height: 136px;
                entries: root.fixture_menu_entries;
                card-bg: card_bg;
                menu-border-color: border_color;
                overlay-hover: overlay_hover;
                overlay-active: overlay_active;
                text-primary: text_primary;
                text-muted: text_muted;
                danger-color: danger_color;
                focus-ring: focus_ring;
            }

            AoToast {
                x: 32px;
                y: parent.height - 92px;
                width: 420px;
                kind: "error";
                message: "Fixture toast";
                detail: "Error copy/action affordances route through AoToast.";
                card-bg: card_bg;
                toast-border-color: border_color;
                text-primary: text_primary;
                text-muted: text_muted;
                success-color: success_color;
                warning-color: warning_color;
                danger-color: danger_color;
            }
        }

        if modal_open && !component_fixture_mode: Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000080;
            property <length> modal-width: min(440px, parent.width - 32px);
            property <length> modal-height: 260px;

            AoModalCard {
                x: (parent.width - parent.modal-width) / 2;
                y: (parent.height - parent.modal-height) / 2;
                width: parent.modal-width;
                height: parent.modal-height;
                card-bg: card_bg;
                card-border-color: focus_ring;

                Text {
                    x: 24px;
                    y: 22px;
                    text: "New task";
                    color: text_primary;
                    font-family: "Lilex Nerd Font Mono";
                    font-size: 20px;
                    font-weight: 700;
                }

                AoAssetIconButton {
                    x: parent.width - 50px;
                    y: 20px;
                    width: 30px;
                    icon-source: @image-url("../../desktop/assets/icons/icons__close.svg");
                    control-label: "Close new task modal";
                    bg: root.overlay_active;
                    hover-bg: root.overlay_hover;
                    border: root.border_color;
                    icon-color: root.text_secondary;
                    clicked => {
                        root.modal_open = false;
                        root.new_task_project_id = "";
                    }
                }

                Text {
                    x: 24px;
                    y: 56px;
                    text: "Slint shell modal matching the GPUI task creation surface.";
                    color: text_muted;
                    font-family: "Lilex Nerd Font Mono";
                    font-size: 12px;
                }

                AoTextInput {
                    x: 24px;
                    y: 92px;
                    width: parent.width - 48px;
                    placeholder-text: "Task name";
                    text <=> root.new_task_name;
                    field-bg: terminal_bg;
                    field-border: border_color;
                    focus-border: focus_ring;
                    error-color: danger_color;
                    text-color: text_primary;
                    placeholder-color: text_muted;
                    error: root.new_task_name == "";
                }

                AoTextInput {
                    x: 24px;
                    y: 142px;
                    width: parent.width - 48px;
                    placeholder-text: "Branch name";
                    text <=> root.new_task_branch;
                    field-bg: terminal_bg;
                    field-border: border_color;
                    focus-border: focus_ring;
                    error-color: danger_color;
                    text-color: text_primary;
                    placeholder-color: text_muted;
                }

                AoButton {
                    x: parent.width - 238px;
                    y: 198px;
                    width: 102px;
                    label: "Cancel";
                    active: false;
                    bg: overlay_active;
                    hover-bg: overlay_hover;
                    border: border_color;
                    text-color: text_secondary;
                    clicked => {
                        root.modal_open = false;
                        root.new_task_project_id = "";
                    }
                }

                AoButton {
                    x: parent.width - 126px;
                    y: 198px;
                    width: 102px;
                    label: "Create";
                    active: true;
                    disabled: root.new_task_name == "";
                    bg: overlay_active;
                    hover-bg: overlay_hover;
                    border: border_color;
                    text-color: text_primary;
                    clicked => {
                        root.submit_new_task(root.new_task_name, root.new_task_branch, root.new_task_project_id);
                        root.modal_open = false;
                        root.new_task_name = "";
                        root.new_task_branch = "";
                        root.new_task_project_id = "";
                    }
                }
            }
        }

        if settings_open && !component_fixture_mode: SettingsView {
            width: parent.width;
            height: parent.height;
            active-section <=> root.settings_active_section;
            nav-entries: root.settings_nav_entries;
            general-rows: root.settings_general_rows;
            agent-rows: root.settings_agent_rows;
            open-in-rows: root.settings_open_in_rows;
            git-action-panels: root.settings_git_action_panels;
            shortcut-rows: root.settings_shortcut_rows;
            mcp-rows: root.settings_mcp_rows;
            chrome-bg: root.chrome_bg;
            card-bg: root.card_bg;
            sunken-bg: root.sunken_bg;
            overlay-hover: root.overlay_hover;
            overlay-active: root.overlay_active;
            settings-border-color: root.border_color;
            focus-ring: root.focus_ring;
            text-primary: root.text_primary;
            text-secondary: root.text_secondary;
            text-muted: root.text_muted;
            danger-color: root.danger_color;
            back-requested => {
                root.settings_open = false;
            }
            nav-selected(section) => {
                root.settings_nav_selected(section);
            }
            toggle-requested(scope, id, enabled) => {
                root.settings_toggle_requested(scope, id, enabled);
            }
            action-requested(scope, id) => {
                root.settings_action_requested(scope, id);
            }
        }

        if toast_message != "" && !component_fixture_mode: AoToast {
            x: parent.width - 402px;
            y: parent.height - footer-height - self.height - 16px;
            width: 386px;
            kind: root.toast_kind;
            message: root.toast_message;
            detail: root.toast_detail;
            card-bg: root.card_bg;
            toast-border-color: root.border_color;
            text-primary: root.text_primary;
            text-muted: root.text_muted;
            success-color: root.success_color;
            warning-color: root.warning_color;
            danger-color: root.danger_color;
            dismissed => {
                root.toast_dismissed();
            }
            copy-requested => {
                root.toast_copy_requested();
            }
        }
    }
}
