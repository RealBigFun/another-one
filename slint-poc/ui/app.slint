import { Button, LineEdit } from "std-widgets.slint";

export struct TerminalTextRun {
    line: int,
    column: int,
    cell-count: int,
    text: string,
    color: color,
    bold: bool,
}

export struct TerminalBackgroundSpan {
    line: int,
    column: int,
    cell-count: int,
    color: color,
}

component SidebarRow inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <bool> active;
    in property <color> overlay_hover;
    in property <color> overlay_active;
    in property <color> text_primary;
    in property <color> text_muted;

    height: 58px;
    border-radius: 10px;
    background: active ? overlay_active : row_touch.has-hover ? overlay_hover : transparent;

    row_touch := TouchArea {
        width: parent.width;
        height: parent.height;
    }

    Rectangle {
        x: 12px;
        y: 16px;
        width: 28px;
        height: 28px;
        border-radius: 8px;
        background: active ? #5d7ad5 : #4d7f58;

        Text {
            x: 0px;
            y: 6px;
            width: parent.width;
            horizontal-alignment: center;
            text: "A";
            color: text_primary;
            font-size: 12px;
            font-weight: 700;
        }
    }

    Text {
        x: 52px;
        y: 11px;
        text: title;
        color: text_primary;
        font-size: 15px;
        font-weight: 700;
    }

    Text {
        x: 52px;
        y: 33px;
        text: subtitle;
        color: text_muted;
        font-size: 12px;
    }
}

export component AppWindow inherits Window {
    in property <color> chrome_bg;
    in property <color> card_bg;
    in property <color> terminal_bg;
    in property <color> overlay_hover;
    in property <color> overlay_active;
    in property <color> focus_ring;
    in property <color> text_primary;
    in property <color> text_secondary;
    in property <color> text_muted;
    in-out property <bool> modal_open: false;
    in-out property <string> terminal_status: "terminal: waiting for daemon-sandbox ticket";
    in property <[TerminalTextRun]> terminal_runs;
    in property <[TerminalBackgroundSpan]> terminal_background_spans;
    callback close_requested();
    callback terminal_key(string, bool, bool, bool);

    title: "AnotherOne Slint POC";
    preferred-width: 1180px;
    preferred-height: 760px;
    background: terminal_bg;

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: terminal_bg;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 44px;
            background: chrome_bg;

            Text {
                x: 18px;
                y: 13px;
                text: "AnotherOne / Slint POC";
                color: text_primary;
                font-size: 14px;
                font-weight: 700;
            }

            Button {
                x: parent.width - 160px;
                y: 8px;
                width: 96px;
                height: 28px;
                text: "New task";
                clicked => {
                    root.modal_open = true;
                }
            }

            Button {
                x: parent.width - 52px;
                y: 8px;
                width: 32px;
                height: 28px;
                text: "x";
                clicked => {
                    root.close_requested();
                }
            }
        }

        Rectangle {
            x: 0px;
            y: 44px;
            width: 296px;
            height: parent.height - 44px;
            background: chrome_bg;

            Text {
                x: 18px;
                y: 18px;
                text: "PROJECTS";
                color: text_muted;
                font-size: 12px;
                font-weight: 700;
            }

            SidebarRow {
                x: 12px;
                y: 48px;
                width: 272px;
                active: true;
                title: "appimage-daemon";
                subtitle: "daemon-transport-foundation";
                overlay_hover: root.overlay_hover;
                overlay_active: root.overlay_active;
                text_primary: root.text_primary;
                text_muted: root.text_muted;
            }

            SidebarRow {
                x: 12px;
                y: 112px;
                width: 272px;
                active: false;
                title: "another-one";
                subtitle: "poc/slint-makepad-ui-eval";
                overlay_hover: root.overlay_hover;
                overlay_active: root.overlay_active;
                text_primary: root.text_primary;
                text_muted: root.text_muted;
            }

            SidebarRow {
                x: 12px;
                y: 176px;
                width: 272px;
                active: false;
                title: "mobile-eval";
                subtitle: "iroh-only terminal baseline";
                overlay_hover: root.overlay_hover;
                overlay_active: root.overlay_active;
                text_primary: root.text_primary;
                text_muted: root.text_muted;
            }
        }

        terminal_surface := Rectangle {
            x: 296px;
            y: 44px;
            width: parent.width - 296px;
            height: parent.height - 44px;
            background: terminal_bg;
            clip: true;
            property <length> terminal-left: 28px;
            property <length> terminal-top: 48px;
            property <length> terminal-cell-width: 8px;
            property <length> terminal-cell-height: 16px;

            terminal_touch := TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => {
                    terminal_focus.focus();
                }
            }

            terminal_focus := FocusScope {
                width: 0px;
                height: 0px;
                key-pressed(event) => {
                    root.terminal_key(
                        event.text,
                        event.modifiers.control,
                        event.modifiers.alt,
                        event.modifiers.shift,
                    );
                    return accept;
                }
            }

            Text {
                x: 28px;
                y: 20px;
                text: root.terminal_status;
                color: text_secondary;
                font-family: "monospace";
                font-size: 13px;
            }

            for span in root.terminal_background_spans: Rectangle {
                x: terminal_surface.terminal-left + span.column * terminal_surface.terminal-cell-width;
                y: terminal_surface.terminal-top + span.line * terminal_surface.terminal-cell-height;
                width: span.cell-count * terminal_surface.terminal-cell-width;
                height: terminal_surface.terminal-cell-height;
                background: span.color;
            }

            for run in root.terminal_runs: Text {
                x: terminal_surface.terminal-left + run.column * terminal_surface.terminal-cell-width;
                y: terminal_surface.terminal-top + run.line * terminal_surface.terminal-cell-height;
                text: run.text;
                color: run.color;
                font-family: "monospace";
                font-size: 13px;
                font-weight: run.bold ? 700 : 400;
            }
        }

        if modal_open: Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000080;

            Rectangle {
                x: (parent.width - 430px) / 2;
                y: (parent.height - 250px) / 2;
                width: 430px;
                height: 250px;
                border-radius: 18px;
                background: card_bg;
                border-width: 1px;
                border-color: focus_ring;

                Text {
                    x: 24px;
                    y: 22px;
                    text: "New task";
                    color: text_primary;
                    font-size: 19px;
                    font-weight: 800;
                }

                Text {
                    x: 24px;
                    y: 56px;
                    text: "Fixture modal used to compare form ergonomics.";
                    color: text_muted;
                    font-size: 12px;
                }

                LineEdit {
                    x: 24px;
                    y: 92px;
                    width: 382px;
                    height: 36px;
                    placeholder-text: "Task name";
                }

                LineEdit {
                    x: 24px;
                    y: 142px;
                    width: 382px;
                    height: 36px;
                    placeholder-text: "Branch name";
                }

                Button {
                    x: 304px;
                    y: 196px;
                    width: 102px;
                    height: 34px;
                    text: "Create";
                    clicked => {
                        root.modal_open = false;
                    }
                }
            }
        }
    }
}
