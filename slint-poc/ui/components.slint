export component AoTabChip inherits Rectangle {
    in property <TerminalTabChip> tab;
    in property <color> overlay-hover;
    in property <color> overlay-active;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> success-color;
    callback clicked(string);
    callback close-clicked(string);
    callback pin-clicked(string);

    height: 30px;
    border-radius: 0px;
    background: tab.active ? #1e1f22 : chip-touch.has-hover ? #2f3136 : #2b2d31;

    chip-touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.clicked(root.tab.id);
        }
    }

    if tab.pinned: Image {
        x: 10px;
        y: 9px;
        width: 12px;
        height: 12px;
        source: @image-url("../../desktop/assets/icons/icons__pin-off.svg");
        colorize: tab.active ? text-primary : text-muted;
    }

    if tab.provider == "shell": Image {
        x: tab.pinned ? 28px : 10px;
        y: 8px;
        width: 14px;
        height: 14px;
        source: @image-url("../../desktop/assets/icons/icons__terminal.svg");
        colorize: tab.active ? text-primary : text-muted;
        opacity: tab.restore-status == "failed" ? 0.62 : 1.0;
    }

    if tab.provider == "claude-code": Image {
        x: tab.pinned ? 28px : 10px;
        y: 8px;
        width: 14px;
        height: 14px;
        source: @image-url("../../desktop/assets/agent-icons/claude.png");
        opacity: tab.restore-status == "failed" ? 0.62 : 1.0;
    }

    if tab.provider == "codex": Image {
        x: tab.pinned ? 28px : 10px;
        y: 8px;
        width: 14px;
        height: 14px;
        source: @image-url("../../desktop/assets/agent-icons/openai.svg");
        opacity: tab.restore-status == "failed" ? 0.62 : 1.0;
    }

    if tab.provider == "cursor-agent": Image {
        x: tab.pinned ? 28px : 10px;
        y: 8px;
        width: 14px;
        height: 14px;
        source: @image-url("../../desktop/assets/agent-icons/cursor.svg");
        opacity: tab.restore-status == "failed" ? 0.62 : 1.0;
    }

    if tab.provider == "gemini": Image {
        x: tab.pinned ? 28px : 10px;
        y: 8px;
        width: 14px;
        height: 14px;
        source: @image-url("../../desktop/assets/agent-icons/gemini.png");
        opacity: tab.restore-status == "failed" ? 0.62 : 1.0;
    }

    Text {
        x: tab.pinned ? 48px : 30px;
        y: 7px;
        width: parent.width - (tab.pinned ? 82px : 64px);
        text: tab.title;
        color: tab.restore-status == "failed" ? #e06c75 : tab.active ? text-primary : text-muted;
        font-family: "Lilex Nerd Font Mono";
        font-size: 12px;
        font-weight: tab.active ? 600 : 500;
    }

    if tab.restore-status == "launching": Image {
        x: parent.width - 42px;
        y: 9px;
        width: 12px;
        height: 12px;
        source: @image-url("../../desktop/assets/icons/icons__spinner.svg");
        colorize: text-muted;
    }

    if tab.restore-status == "failed": Image {
        x: parent.width - 42px;
        y: 9px;
        width: 12px;
        height: 12px;
        source: @image-url("../../desktop/assets/icons/icons__alert-triangle.svg");
        colorize: #e06c75;
    }

    if !tab.pinned && tab.restore-status == "ready" && (chip-touch.has-hover || tab.active): Rectangle {
        x: parent.width - 46px;
        y: 6px;
        width: 18px;
        height: 18px;
        border-radius: 4px;
        background: hover-pin-touch.has-hover ? #ffffff14 : transparent;

        Image {
            x: 3px;
            y: 3px;
            width: 12px;
            height: 12px;
            source: @image-url("../../desktop/assets/icons/icons__pin-off.svg");
            colorize: hover-pin-touch.has-hover ? text-primary : text-muted;
        }

        hover-pin-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            accessible-role: button;
            accessible-label: "Pin tab " + root.tab.title;
            clicked => {
                root.pin-clicked(root.tab.id);
            }
        }
    }

    if chip-touch.has-hover || tab.active: Rectangle {
        x: parent.width - 24px;
        y: 6px;
        width: 18px;
        height: 18px;
        border-radius: 4px;
        background: close-touch.has-hover ? #ffffff14 : transparent;

        Image {
            x: 3px;
            y: 3px;
            width: 12px;
            height: 12px;
            source: @image-url("../../desktop/assets/icons/icons__close.svg");
            colorize: close-touch.has-hover ? text-primary : text-muted;
        }

        close-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            accessible-role: button;
            accessible-label: "Close tab " + root.tab.title;
            clicked => {
                root.close-clicked(root.tab.id);
            }
        }
    }

    pin-touch := TouchArea {
        x: 0px;
        y: 0px;
        width: tab.pinned ? 28px : 0px;
        height: parent.height;
        accessible-role: button;
        accessible-label: tab.pinned ? "Unpin tab " + root.tab.title : "Pin tab " + root.tab.title;
        clicked => {
            root.pin-clicked(root.tab.id);
        }
    }
}

export component AoCard inherits Rectangle {
    in property <string> title;
    in property <string> body;
    in property <color> card-bg;
    in property <color> card-border-color;
    in property <color> text-primary;
    in property <color> text-muted;

    height: 88px;
    border-radius: 12px;
    border-width: 1px;
    border-color: card-border-color;
    background: card-bg;

    Text {
        x: 14px;
        y: 12px;
        width: parent.width - 28px;
        text: title;
        color: text-primary;
        font-family: "Lilex Nerd Font Mono";
        font-size: 12px;
        font-weight: 600;
    }

    Text {
        x: 14px;
        y: 36px;
        width: parent.width - 28px;
        text: body;
        color: text-muted;
        font-family: "Lilex Nerd Font Mono";
        font-size: 11px;
    }
}

export component AoStateCard inherits Rectangle {
    in property <string> title;
    in property <string> body;
    in property <string> state: "populated";
    in property <string> action-label: "";
    in property <color> card-bg;
    in property <color> card-border-color;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> success-color;
    in property <color> warning-color;
    in property <color> danger-color;
    callback action-clicked();

    height: 104px;
    border-radius: 12px;
    border-width: 1px;
    border-color: state == "error" ? danger-color : state == "loading" ? warning-color : card-border-color;
    background: card-bg;

    Rectangle {
        x: 14px;
        y: 14px;
        width: 8px;
        height: 8px;
        border-radius: 4px;
        background: state == "error" ? danger-color : state == "loading" ? warning-color : state == "empty" ? text-muted : success-color;
        opacity: state == "empty" ? 0.42 : 1.0;
    }

    Text {
        x: 30px;
        y: 10px;
        width: parent.width - 44px;
        text: title;
        color: text-primary;
        font-family: "Lilex Nerd Font Mono";
        font-size: 12px;
        font-weight: 600;
    }

    Text {
        x: 14px;
        y: 36px;
        width: parent.width - 28px;
        text: state == "loading" ? "Loading..." : body;
        color: state == "error" ? danger-color : text-muted;
        font-family: "Lilex Nerd Font Mono";
        font-size: 11px;
    }

    if action-label != "": AoButton {
        x: 14px;
        y: parent.height - 34px;
        width: 96px;
        label: action-label;
        bg: root.card-bg;
        hover-bg: root.card-border-color;
        border: root.card-border-color;
        text-color: root.text-primary;
        active: false;
        clicked => {
            root.action-clicked();
        }
    }
}

export component AoInspectorModeButton inherits Rectangle {
    in property <string> label;
    in property <image> icon-source;
    in property <bool> active: false;
    in property <bool> disabled: false;
    in property <color> hover-bg;
    in property <color> active-bg;
    in property <color> border;
    in property <color> text-primary;
    in property <color> text-muted;
    callback clicked();

    height: 30px;
    accessible-role: button;
    accessible-label: label;
    border-radius: 7px;
    border-width: active ? 1px : 0px;
    border-color: active ? border : transparent;
    background: active ? active-bg : touch.has-hover && !disabled ? hover-bg : transparent;
    opacity: disabled ? 0.55 : 1.0;

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            if !root.disabled {
                root.clicked();
            }
        }
    }

    Image {
        x: 8px;
        y: 9px;
        width: 12px;
        height: 12px;
        source: root.icon-source;
        colorize: root.active ? root.text-primary : root.text-muted;
    }

    Text {
        x: 26px;
        y: 8px;
        width: parent.width - 32px;
        text: root.label;
        color: root.active ? root.text-primary : root.text-muted;
        font-family: "Lilex Nerd Font Mono";
        font-size: 11px;
        font-weight: 600;
    }
}

export component AoDiffBadge inherits Text {
    in property <bool> positive: true;

    color: positive ? #8bd99c : #e58b95;
    font-family: "Lilex Nerd Font Mono";
    font-size: 11px;
    font-weight: 700;
}

export component AoInspectorSectionRow inherits Rectangle {
    in property <RightInspectorRow> entry;
    in property <color> row-border-color;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> hover-bg;
    in property <color> icon-color;
    callback toggled(string);
    callback stage-all-clicked(string);
    callback unstage-all-clicked(string);

    height: 44px;
    background: touch.has-hover ? hover-bg : transparent;
    border-width: 0px;

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.toggled(root.entry.group);
        }
    }

    Rectangle {
        x: 0px;
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: root.row-border-color;
    }

    Image {
        x: 14px;
        y: 17px;
        width: 10px;
        height: 10px;
        source: root.entry.expanded ? @image-url("../../desktop/assets/icons/icons__chevron-down.svg") : @image-url("../../desktop/assets/icons/icons__chevron-right.svg");
        colorize: root.text-muted;
    }

    Text {
        x: 30px;
        y: 15px;
        width: parent.width - 174px;
        text: entry.title + " (" + entry.file-count-label + ")";
        color: root.text-primary;
        font-family: "Lilex Nerd Font Mono";
        font-size: 11px;
        font-weight: 700;
    }

    if entry.additions-label != "": AoDiffBadge {
        x: parent.width - 128px;
        y: 15px;
        width: 36px;
        text: entry.additions-label;
        positive: true;
    }

    if entry.deletions-label != "": AoDiffBadge {
        x: parent.width - 86px;
        y: 15px;
        width: 36px;
        text: entry.deletions-label;
        positive: false;
    }

    if entry.pending: Image {
        x: parent.width - 30px;
        y: 16px;
        width: 14px;
        height: 14px;
        source: @image-url("../../desktop/assets/icons/icons__refresh.svg");
        colorize: root.icon-color;
    }

    if entry.group == "staged" && !entry.pending: AoAssetIconButton {
        x: parent.width - 38px;
        y: 8px;
        width: 28px;
        height: 28px;
        icon-source: @image-url("../../desktop/assets/icons/icons__minus.svg");
        control-label: "Unstage all files in " + entry.title;
        bg: transparent;
        hover-bg: #ffffff14;
        border: root.row-border-color;
        icon-color: root.icon-color;
        clicked => {
            root.unstage-all-clicked(root.entry.project-id);
        }
    }

    if entry.group == "unstaged" && !entry.pending: AoAssetIconButton {
        x: parent.width - 38px;
        y: 8px;
        width: 28px;
        height: 28px;
        icon-source: @image-url("../../desktop/assets/icons/icons__plus.svg");
        control-label: "Stage all files in " + entry.title;
        bg: transparent;
        hover-bg: #ffffff14;
        border: root.row-border-color;
        icon-color: root.icon-color;
        clicked => {
            root.stage-all-clicked(root.entry.project-id);
        }
    }
}

export component AoInspectorFileRow inherits Rectangle {
    in property <RightInspectorRow> entry;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> hover-bg;
    in property <color> action-hover-bg;
    in property <color> icon-color;
    in property <color> row-border-color;
    callback stage-file-clicked(string, string, bool);
    callback unstage-file-clicked(string, string, bool);
    callback discard-file-clicked(string, string, bool);

    height: 34px;
    border-radius: 7px;
    background: touch.has-hover ? hover-bg : transparent;

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
    }

    Text {
        x: 18px;
        y: 9px;
        width: 18px;
        text: entry.status;
        color: entry.status-color;
        font-family: "Lilex Nerd Font Mono";
        font-size: 12px;
        font-weight: 700;
    }

    Text {
        x: 42px;
        y: 9px;
        width: entry.parent-dir == "" ? parent.width - 178px : min(150px, parent.width - 238px);
        text: entry.title;
        color: root.text-primary;
        font-family: "Lilex Nerd Font Mono";
        font-size: 12px;
        font-weight: 600;
        overflow: elide;
    }

    if entry.parent-dir != "": Text {
        x: 42px + min(156px, parent.width - 232px);
        y: 10px;
        width: max(48px, parent.width - 270px);
        text: entry.parent-dir;
        color: root.text-muted;
        font-family: "Lilex Nerd Font Mono";
        font-size: 11px;
        overflow: elide;
    }

    if entry.additions-label != "": AoDiffBadge {
        x: parent.width - 142px;
        y: 9px;
        width: 34px;
        text: entry.additions-label;
        positive: true;
    }

    if entry.deletions-label != "": AoDiffBadge {
        x: parent.width - 104px;
        y: 9px;
        width: 34px;
        text: entry.deletions-label;
        positive: false;
    }

    if entry.pending: Image {
        x: parent.width - 30px;
        y: 10px;
        width: 14px;
        height: 14px;
        source: @image-url("../../desktop/assets/icons/icons__refresh.svg");
        colorize: root.icon-color;
    }

    if entry.group == "staged" && !entry.pending: AoAssetIconButton {
        x: parent.width - 38px;
        y: 3px;
        width: 28px;
        height: 28px;
        icon-source: @image-url("../../desktop/assets/icons/icons__minus.svg");
        control-label: "Unstage " + entry.title;
        disabled: !entry.can-unstage;
        bg: transparent;
        hover-bg: root.action-hover-bg;
        border: root.row-border-color;
        icon-color: root.icon-color;
        clicked => {
            root.unstage-file-clicked(root.entry.path, root.entry.original-path, root.entry.untracked);
        }
    }

    if entry.group == "unstaged" && !entry.pending: AoAssetIconButton {
        x: parent.width - 70px;
        y: 3px;
        width: 28px;
        height: 28px;
        icon-source: @image-url("../../desktop/assets/icons/icons__plus.svg");
        control-label: "Stage " + entry.title;
        disabled: !entry.can-stage;
        bg: transparent;
        hover-bg: root.action-hover-bg;
        border: root.row-border-color;
        icon-color: root.icon-color;
        clicked => {
            root.stage-file-clicked(root.entry.path, root.entry.original-path, root.entry.untracked);
        }
    }

    if entry.group == "unstaged" && !entry.pending: AoAssetIconButton {
        x: parent.width - 38px;
        y: 3px;
        width: 28px;
        height: 28px;
        icon-source: @image-url("../../desktop/assets/icons/icons__discard.svg");
        control-label: "Discard " + entry.title;
        bg: transparent;
        hover-bg: root.action-hover-bg;
        border: root.row-border-color;
        icon-color: root.icon-color;
        clicked => {
            root.discard-file-clicked(root.entry.path, root.entry.original-path, root.entry.untracked);
        }
    }
}

export component AoInspectorCommitRow inherits Rectangle {
    in property <RightInspectorRow> entry;
