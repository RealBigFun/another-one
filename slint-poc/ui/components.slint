export component AoInspectorCheckRow inherits Rectangle {
    in property <RightInspectorRow> entry;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> hover-bg;
    in property <color> action-hover-bg;
    in property <color> icon-color;
    callback open-requested(string);

    height: 46px;
    border-radius: 7px;
    background: touch.has-hover ? hover-bg : transparent;

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
    }

    Image {
        x: 14px;
        y: 15px;
        width: 16px;
        height: 16px;
        source: entry.group == "pass" ? @image-url("../../desktop/assets/icons/icons__badge-check.svg") : entry.group == "fail" ? @image-url("../../desktop/assets/icons/icons__badge-x.svg") : entry.group == "pending" ? @image-url("../../desktop/assets/icons/icons__badge-clock.svg") : @image-url("../../desktop/assets/icons/icons__minus.svg");
        colorize: entry.status-color;
    }

    Text {
        x: 40px;
        y: 8px;
        width: parent.width - 132px;
        text: entry.title;
        color: root.text-primary;
        font-family: "Lilex Nerd Font Mono";
        font-size: 12px;
        font-weight: 600;
        overflow: elide;
    }

    Text {
        x: 40px;
        y: 26px;
        width: parent.width - 132px;
        text: entry.parent-dir;
        color: root.text-muted;
        font-family: "Lilex Nerd Font Mono";
        font-size: 11px;
        overflow: elide;
    }

    Text {
        x: entry.path == "" ? parent.width - 82px : parent.width - 112px;
        y: 16px;
        width: 68px;
        horizontal-alignment: right;
        text: entry.additions-label;
        color: root.text-muted;
        font-family: "Lilex Nerd Font Mono";
        font-size: 11px;
        font-weight: 600;
    }

    if entry.path != "": AoAssetIconButton {
        x: parent.width - 38px;
        y: 9px;
        width: 28px;
        height: 28px;
        icon-source: @image-url("../../desktop/assets/icons/icons__external-link.svg");
        control-label: "Open check " + entry.title;
        bg: transparent;
        hover-bg: root.action-hover-bg;
        border: transparent;
        icon-color: root.icon-color;
        clicked => {
            root.open-requested(root.entry.path);
        }
    }
}

export component AoTextInput inherits Rectangle {
    in property <string> placeholder-text;
    in-out property <string> text <=> input.text;
    in property <color> field-bg;
    in property <color> field-border;
    in property <color> focus-border: field-border;
    in property <color> error-color: field-border;
    in property <bool> error: false;
    in property <bool> disabled: false;
    in property <color> text-color: #ebebeb;
    in property <color> placeholder-color: #949494;

    height: 36px;
    border-radius: 9px;
    border-width: 1px;
    border-color: error ? error-color : input.has-focus ? focus-border : field-border;
    background: field-bg;
    opacity: disabled ? 0.52 : 1.0;
    clip: true;

    if root.text == "" && !input.has-focus: Text {
        x: 8px;
        y: 10px;
        width: parent.width - 16px;
        text: root.placeholder-text;
        color: root.placeholder-color;
        font-family: "Lilex Nerd Font Mono";
        font-size: 12px;
        font-weight: 400;
    }

    input := TextInput {
        x: 8px;
        y: 0px;
        width: parent.width - 16px;
        height: parent.height;
        enabled: !root.disabled;
        font-family: "Lilex Nerd Font Mono";
        font-size: 12px;
        font-weight: 400;
        color: root.text-color;
        selection-background-color: root.focus-border.with-alpha(0.42);
        selection-foreground-color: root.text-color;
        vertical-alignment: center;
    }
}

export component AoModalCard inherits Rectangle {
    in property <color> card-bg;
    in property <color> card-border-color;

    width: 440px;
    height: 260px;
    border-radius: 18px;
    background: card-bg;
    border-width: 1px;
    border-color: card-border-color;
}

export component AoMenuItem inherits Rectangle {
    in property <MenuEntry> entry;
    in property <color> overlay-hover;
    in property <color> overlay-active;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> danger-color;
    in property <color> focus-ring: overlay-active;
    callback clicked(string);

    height: 30px;
    accessible-role: button;
    accessible-label: entry.label;
    border-radius: 8px;
    border-width: item-focus.has-focus ? 1px : 0px;
    border-color: focus-ring;
    background: entry.selected ? overlay-active : item-touch.has-hover && !entry.disabled ? overlay-hover : transparent;
    opacity: entry.disabled ? 0.45 : 1.0;

    item-focus := FocusScope {
        width: 0px;
        height: 0px;
        key-pressed(event) => {
            if !root.entry.disabled && (event.text == "\n" || event.text == " ") {
                root.clicked(root.entry.id);
                return accept;
            }
            return reject;
        }
    }

    item-touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            item-focus.focus();
            if !root.entry.disabled {
                root.clicked(root.entry.id);
            }
        }
    }

    Text {
        x: 10px;
        y: 7px;
        width: parent.width - 92px;
        text: entry.label;
        color: entry.destructive ? danger-color : text-primary;
        font-family: "Lilex Nerd Font Mono";
        font-size: 12px;
        font-weight: entry.selected ? 600 : 500;
    }

    Text {
        x: parent.width - 78px;
        y: 8px;
        width: 66px;
        horizontal-alignment: right;
        text: entry.shortcut;
        color: text-muted;
        font-family: "Lilex Nerd Font Mono";
        font-size: 10px;
    }
}

export component AoMenu inherits Rectangle {
    in property <[MenuEntry]> entries;
    in property <color> card-bg;
    in property <color> menu-border-color;
    in property <color> overlay-hover;
    in property <color> overlay-active;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> danger-color;
    in property <color> focus-ring: overlay-active;
    callback item-clicked(string);

    border-radius: 12px;
    border-width: 1px;
    border-color: menu-border-color;
    background: card-bg;

    for entry[index] in entries: AoMenuItem {
        x: 6px;
        y: 6px + index * 32px;
        width: parent.width - 12px;
        entry: entry;
        overlay-hover: root.overlay-hover;
        overlay-active: root.overlay-active;
        text-primary: root.text-primary;
        text-muted: root.text-muted;
        danger-color: root.danger-color;
        focus-ring: root.focus-ring;
        clicked(id) => {
            root.item-clicked(id);
        }
    }
}

export component AoTooltip inherits Rectangle {
    in property <string> message;
    in property <color> card-bg;
    in property <color> tooltip-border-color;
    in property <color> text-color;

    height: 28px;
    border-radius: 8px;
    border-width: 1px;
    border-color: tooltip-border-color;
    background: card-bg;

    Text {
        x: 10px;
        y: 7px;
        width: parent.width - 20px;
        text: message;
        color: text-color;
        font-family: "Lilex Nerd Font Mono";
        font-size: 11px;
        font-weight: 700;
    }
}

export component AoToast inherits Rectangle {
    in property <string> kind: "info";
    in property <string> message;
    in property <string> detail: "";
    in property <color> card-bg;
    in property <color> toast-border-color;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> success-color;
    in property <color> warning-color;
    in property <color> danger-color;
    callback dismissed();
    callback copy-requested();

    height: detail == "" ? 54px : 74px;
    border-radius: 14px;
    border-width: 1px;
    border-color: kind == "error" ? danger-color : kind == "warning" ? warning-color : kind == "success" ? success-color : toast-border-color;
    background: card-bg;

    Rectangle {
        x: 14px;
        y: 16px;
        width: 9px;
        height: 9px;
        border-radius: 5px;
        background: kind == "error" ? danger-color : kind == "warning" ? warning-color : kind == "success" ? success-color : text-muted;
    }

    Text {
        x: 32px;
        y: 10px;
        width: parent.width - 96px;
        text: message;
        color: text-primary;
        font-family: "Lilex Nerd Font Mono";
        font-size: 12px;
        font-weight: 600;
    }

    if detail != "": Text {
        x: 32px;
        y: 32px;
        width: parent.width - 96px;
        text: detail;
        color: kind == "error" ? danger-color : text-muted;
        font-family: "Lilex Nerd Font Mono";
        font-size: 11px;
    }

    AoAssetIconButton {
        x: parent.width - 62px;
        y: 14px;
        icon-source: @image-url("../../desktop/assets/icons/icons__copy.svg");
        control-label: "Copy notification details";
        bg: root.card-bg;
        hover-bg: root.toast-border-color;
        border: root.toast-border-color;
        icon-color: root.text-muted;
        clicked => {
            root.copy-requested();
        }
    }

    AoAssetIconButton {
        x: parent.width - 30px;
        y: 14px;
        icon-source: @image-url("../../desktop/assets/icons/icons__close.svg");
        control-label: "Dismiss notification";
        bg: root.card-bg;
        hover-bg: root.toast-border-color;
        border: root.toast-border-color;
        icon-color: root.text-muted;
        clicked => {
            root.dismissed();
        }
    }
}
