export component AoButton inherits Rectangle {
    in property <string> label;
    in property <string> control-label: label;
    in property <bool> active: false;
    in property <bool> disabled: false;
    in property <bool> loading: false;
    in property <bool> destructive: false;
    in property <color> bg;
    in property <color> hover-bg;
    in property <color> border;
    in property <color> focus-ring: border;
    in property <color> text-color;
    in property <color> danger-color: text-color;
    callback clicked();

    height: 26px;
    accessible-role: button;
    accessible-label: control-label;
    border-radius: 8px;
    border-width: 1px;
    border-color: button-focus.has-focus ? focus-ring : active ? border : transparent;
    opacity: disabled ? 0.45 : 1.0;
    background: active || touch.pressed ? bg : touch.has-hover && !disabled ? hover-bg : transparent;

    button-focus := FocusScope {
        width: 0px;
        height: 0px;
        key-pressed(event) => {
            if !root.disabled && !root.loading && (event.text == "\n" || event.text == " ") {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            button-focus.focus();
            if !root.disabled && !root.loading {
                root.clicked();
            }
        }
    }

    Text {
        x: 10px;
        y: 6px;
        width: parent.width - 20px;
        text: loading ? "..." : label;
        color: destructive ? danger-color : text-color;
        font-family: "Lilex Nerd Font Mono";
        font-size: 12px;
        font-weight: 700;
    }
}

export component AoIconButton inherits Rectangle {
    in property <string> icon;
    in property <string> control-label;
    in property <bool> active: false;
    in property <bool> disabled: false;
    in property <color> bg;
    in property <color> hover-bg;
    in property <color> border;
    in property <color> focus-ring: border;
    in property <color> icon-color;
    callback clicked();

    width: 30px;
    height: 26px;
    accessible-role: button;
    accessible-label: control-label;
    border-radius: 8px;
    border-width: active || icon-focus.has-focus ? 1px : 0px;
    border-color: icon-focus.has-focus ? focus-ring : border;
    background: active || icon-touch.pressed ? bg : icon-touch.has-hover && !disabled ? hover-bg : transparent;
    opacity: disabled ? 0.42 : 1.0;

    icon-focus := FocusScope {
        width: 0px;
        height: 0px;
        key-pressed(event) => {
            if !root.disabled && (event.text == "\n" || event.text == " ") {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }

    icon-touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            icon-focus.focus();
            if !root.disabled {
                root.clicked();
            }
        }
    }

    Text {
        x: 0px;
        y: 5px;
        width: parent.width;
        horizontal-alignment: center;
        text: icon;
        color: icon-color;
        font-family: "Lilex Nerd Font Mono";
        font-size: 13px;
        font-weight: 700;
    }
}

export component AoAssetIconButton inherits Rectangle {
    in property <image> icon-source;
    in property <string> control-label;
    in property <bool> active: false;
    in property <bool> disabled: false;
    in property <color> bg;
    in property <color> hover-bg;
    in property <color> border;
    in property <color> focus-ring: border;
    in property <color> icon-color;
    callback clicked();

    width: 30px;
    height: 26px;
    accessible-role: button;
    accessible-label: control-label;
    border-radius: 8px;
    border-width: active || icon-focus.has-focus ? 1px : 0px;
    border-color: icon-focus.has-focus ? focus-ring : border;
    background: active || icon-touch.pressed ? bg : icon-touch.has-hover && !disabled ? hover-bg : transparent;
    opacity: disabled ? 0.42 : 1.0;

    icon-focus := FocusScope {
        width: 0px;
        height: 0px;
        key-pressed(event) => {
            if !root.disabled && (event.text == "\n" || event.text == " ") {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }

    icon-touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            icon-focus.focus();
            if !root.disabled {
                root.clicked();
            }
        }
    }

    Image {
        x: (parent.width - 14px) / 2;
        y: (parent.height - 14px) / 2;
        width: 14px;
        height: 14px;
        source: root.icon-source;
        colorize: root.icon-color;
    }
}

export component AoSplitButton inherits Rectangle {
    in property <string> label;
    in property <string> control-label: label;
    in property <string> menu-control-label: label + " menu";
    in property <bool> active: false;
    in property <bool> disabled: false;
    in property <color> bg;
    in property <color> hover-bg;
    in property <color> border;
    in property <color> focus-ring: border;
    in property <color> text-color;
    callback clicked();
    callback menu-clicked();

    height: 26px;
    accessible-role: button;
    accessible-label: control-label;
    border-radius: 8px;
    border-width: 1px;
    border-color: split-focus.has-focus || menu-focus.has-focus ? focus-ring : border;
    background: active || split-touch.pressed || menu-touch.pressed ? bg : (split-touch.has-hover || menu-touch.has-hover) && !disabled ? hover-bg : transparent;
    opacity: disabled ? 0.45 : 1.0;

    split-focus := FocusScope {
        width: 0px;
        height: 0px;
        key-pressed(event) => {
            if !root.disabled && (event.text == "\n" || event.text == " ") {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }

    menu-focus := FocusScope {
        width: 0px;
        height: 0px;
        key-pressed(event) => {
            if !root.disabled && (event.text == "\n" || event.text == " ") {
                root.menu-clicked();
                return accept;
            }
            return reject;
        }
    }

    split-touch := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width - 30px;
        height: parent.height;
        clicked => {
            split-focus.focus();
            if !root.disabled {
                root.clicked();
            }
        }
    }

    Rectangle {
        x: parent.width - 30px;
        y: 0px;
        width: 1px;
        height: parent.height;
        background: border;
        opacity: 0.6;
    }

    menu-touch := TouchArea {
        x: parent.width - 30px;
        y: 0px;
        width: 30px;
        height: parent.height;
        accessible-role: button;
        accessible-label: root.menu-control-label;
        clicked => {
            menu-focus.focus();
            if !root.disabled {
                root.menu-clicked();
            }
        }
    }

    Text {
        x: 10px;
        y: 6px;
        width: parent.width - 44px;
        text: label;
        color: text-color;
        font-family: "Lilex Nerd Font Mono";
        font-size: 12px;
        font-weight: 600;
    }

    Text {
        x: parent.width - 24px;
        y: 6px;
        width: 18px;
        horizontal-alignment: center;
        text: "v";
        color: text-color;
        font-family: "Lilex Nerd Font Mono";
        font-size: 11px;
        font-weight: 700;
    }
}

export component AoCheckbox inherits Rectangle {
    in-out property <bool> checked;
    in property <string> label;
    in property <string> control-label: label;
    in property <bool> disabled: false;
    in property <bool> error: false;
    in property <color> bg;
    in property <color> hover-bg;
    in property <color> border;
    in property <color> focus-ring: border;
    in property <color> text-color;
    in property <color> danger-color: text-color;
    callback toggled(bool);

    height: 28px;
    accessible-role: checkbox;
    accessible-label: control-label;
    border-radius: 7px;
    opacity: disabled ? 0.45 : 1.0;

    checkbox-focus := FocusScope {
        width: 0px;
        height: 0px;
        key-pressed(event) => {
            if !root.disabled && (event.text == "\n" || event.text == " ") {
                root.checked = !root.checked;
                root.toggled(root.checked);
                return accept;
            }
            return reject;
        }
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            checkbox-focus.focus();
            if !root.disabled {
                root.checked = !root.checked;
                root.toggled(root.checked);
            }
        }
    }

    Rectangle {
        x: 0px;
        y: 5px;
        width: 18px;
        height: 18px;
        border-radius: 5px;
        border-width: 1px;
        border-color: root.error ? root.danger-color : checkbox-focus.has-focus ? root.focus-ring : root.border;
        background: root.checked ? root.bg : touch.has-hover && !root.disabled ? root.hover-bg : transparent;
    }

    if checked: Text {
        x: 4px;
        y: 6px;
        width: 10px;
        text: "x";
        color: text-color;
        font-family: "Lilex Nerd Font Mono";
        font-size: 11px;
        font-weight: 700;
    }

    Text {
        x: 28px;
        y: 6px;
        width: parent.width - 28px;
        text: label;
        color: error ? danger-color : text-color;
        font-family: "Lilex Nerd Font Mono";
        font-size: 12px;
        font-weight: 700;
    }
}

export component AoSegmentedControl inherits Rectangle {
    in property <[SegmentEntry]> entries;
    in property <color> bg;
    in property <color> hover-bg;
    in property <color> border;
    in property <color> focus-ring: border;
    in property <color> text-color;
    in property <color> muted-color;
    callback selected(string);

    height: 30px;
    border-radius: 9px;
    border-width: 1px;
    border-color: border;
    background: bg;
    clip: true;

    for entry[index] in entries: Rectangle {
        x: index * parent.width / max(1, entries.length);
        y: 3px;
        width: parent.width / max(1, entries.length);
        height: parent.height - 6px;
        border-radius: 7px;
        border-width: segment-focus.has-focus ? 1px : 0px;
        border-color: root.focus-ring;
        background: entry.selected ? root.hover-bg : segment-touch.has-hover && !entry.disabled ? root.hover-bg.with-alpha(0.64) : transparent;
        opacity: entry.disabled ? 0.45 : 1.0;

        segment-focus := FocusScope {
            width: 0px;
            height: 0px;
            key-pressed(event) => {
                if !entry.disabled && (event.text == "\n" || event.text == " ") {
                    root.selected(entry.id);
                    return accept;
                }
                return reject;
            }
        }

        segment-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                segment-focus.focus();
                if !entry.disabled {
                    root.selected(entry.id);
                }
            }
        }

        Text {
            x: 8px;
            y: 6px;
            width: parent.width - 16px;
            horizontal-alignment: center;
            text: entry.label;
            color: entry.selected ? root.text-color : root.muted-color;
            font-family: "Lilex Nerd Font Mono";
            font-size: 11px;
            font-weight: entry.selected ? 600 : 500;
        }
    }
}

export component AoStatusPill inherits Rectangle {
    in property <string> label;
    in property <string> kind: "neutral";
    in property <color> bg;
    in property <color> border;
    in property <color> text-color;
    in property <color> success-color: text-color;
    in property <color> warning-color: text-color;
    in property <color> danger-color: text-color;

    height: 24px;
    border-radius: 12px;
    border-width: 1px;
    border-color: border;
    background: bg;

    Text {
        x: 12px;
        y: 5px;
        width: parent.width - 24px;
        text: label;
        color: kind == "success" ? success-color : kind == "warning" ? warning-color : kind == "danger" ? danger-color : text-color;
        font-family: "Lilex Nerd Font Mono";
        font-size: 12px;
        font-weight: 700;
    }
}

export component AoResourceIndicator inherits Rectangle {
    in property <string> label;
    in property <color> bg;
    in property <color> border;
    in property <color> text-color;
    in property <color> warning-color;
    in property <color> danger-color;
    in property <bool> active: false;
    in property <bool> warning: false;
    in property <bool> danger: false;

    height: 24px;
    border-radius: 12px;
    border-width: 1px;
    border-color: danger ? danger-color : warning ? warning-color : active ? text-color.with-alpha(0.72) : border;
    background: bg;

    Text {
        x: 12px;
        y: 5px;
        width: parent.width - 24px;
        text: label;
        color: danger ? danger-color : warning ? warning-color : text-color;
        font-family: "Lilex Nerd Font Mono";
        font-size: 12px;
        font-weight: 600;
    }
}

export component AoSectionLabel inherits Text {
    in property <color> label-color;

    color: label-color;
    font-family: "Lilex Nerd Font Mono";
    font-size: 11px;
    font-weight: 600;
}

export component AoAvatar inherits Rectangle {
    in property <string> label;
    in property <color> accent;
    in property <color> text-color;

    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: accent;

    Text {
        x: 0px;
        y: 6px;
        width: parent.width;
        horizontal-alignment: center;
        text: label;
        color: text-color;
        font-family: "Lilex Nerd Font Mono";
        font-size: 12px;
        font-weight: 700;
    }
}

export component AoProjectRow inherits Rectangle {
    in property <ProjectSidebarEntry> entry;
    in property <color> overlay-hover;
    in property <color> overlay-active;
    in property <color> active-border: overlay-active;
    in property <color> icon-color: text-muted;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> text-secondary;
    in property <color> focus-ring: overlay-active;
    in property <color> danger-color: text-primary;
    in property <color> warning-color: text-secondary;
    callback clicked(string);
    callback menu-clicked(string);
    callback add-clicked(string);
    callback github-clicked(string);

    height: 66px;
    border-radius: 11px;
    border-width: row-focus.has-focus || entry.active || entry.error ? 1px : 0px;
    border-color: entry.error ? danger-color : row-focus.has-focus ? focus-ring : overlay-active;
    background: entry.active || row-touch.pressed ? overlay-active : row-touch.has-hover ? overlay-hover : transparent;

    row-focus := FocusScope {
        width: 0px;
        height: 0px;
        key-pressed(event) => {
            if event.text == "\n" || event.text == " " {
                root.clicked(root.entry.id);
                return accept;
            }
            return reject;
        }
    }

    row-touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            row-focus.focus();
            root.clicked(root.entry.id);
        }
    }

    AoAvatar {
        x: 12px;
        y: 11px;
        label: entry.initials;
        accent: entry.accent;
        text-color: text-primary;
    }

    Text {
        x: 52px;
        y: 9px;
        width: parent.width - 104px;
        text: entry.name;
        color: text-primary;
        font-family: "Lilex Nerd Font Mono";
        font-size: 14px;
        font-weight: 600;
    }

    Text {
        x: parent.width - 84px;
        y: 10px;
        width: 18px;
        horizontal-alignment: center;
        text: entry.expanded ? "v" : ">";
        color: text-muted;
        font-family: "Lilex Nerd Font Mono";
        font-size: 10px;
        font-weight: 700;
    }

    Text {
        x: 52px;
        y: 29px;
        width: parent.width - 74px;
        text: entry.loading ? "loading project..." : entry.error ? "project unavailable" : entry.branch;
        color: entry.error ? danger-color : entry.loading ? warning-color : text-muted;
        font-family: "Lilex Nerd Font Mono";
        font-size: 11px;
    }

    Text {
        x: parent.width - 45px;
        y: 13px;
        width: 32px;
        horizontal-alignment: right;
        text: entry.task-count-label;
        color: text-secondary;
        font-family: "Lilex Nerd Font Mono";
        font-size: 11px;
        font-weight: 700;
    }

    Text {
        x: 52px;
        y: 46px;
        width: parent.width - 66px;
        text: entry.path;
        color: text-muted;
        font-family: "Lilex Nerd Font Mono";
        font-size: 10px;
    }

    if row-touch.has-hover || row-focus.has-focus: Rectangle {
        x: parent.width - 112px;
        y: 38px;
        width: 96px;
        height: 20px;
        border-radius: 7px;
        background: overlay-hover;

        Text {
            x: 7px;
            y: 5px;
            text: "+";
            color: text-secondary;
            font-family: "Lilex Nerd Font Mono";
            font-size: 10px;
            font-weight: 700;
        }

        add-touch := TouchArea {
            x: 0px;
            y: 0px;
            width: 28px;
            height: parent.height;
            accessible-role: button;
            accessible-label: "New task for " + root.entry.name;
            clicked => {
                row-focus.focus();
                root.add-clicked(root.entry.id);
            }
        }

        Text {
            x: 39px;
            y: 5px;
            text: "gh";
            color: text-secondary;
            font-family: "Lilex Nerd Font Mono";
            font-size: 10px;
            font-weight: 600;
        }

        github-touch := TouchArea {
            x: 30px;
            y: 0px;
            width: 34px;
            height: parent.height;
            accessible-role: button;
            accessible-label: "Open repository for " + root.entry.name;
            clicked => {
                row-focus.focus();
                root.github-clicked(root.entry.id);
            }
        }

        Text {
            x: 76px;
            y: 5px;
            text: "...";
            color: text-secondary;
            font-family: "Lilex Nerd Font Mono";
            font-size: 10px;
            font-weight: 600;
        }

        menu-touch := TouchArea {
            x: 66px;
            y: 0px;
            width: 30px;
            height: parent.height;
            accessible-role: button;
            accessible-label: "Project menu for " + root.entry.name;
            clicked => {
                row-focus.focus();
                root.menu-clicked(root.entry.id);
            }
        }
    }
}

export component AoSidebarProjectRow inherits Rectangle {
    in property <ProjectSidebarEntry> entry;
    in property <color> overlay-hover;
    in property <color> overlay-active;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> focus-ring: overlay-active;
    in property <color> danger-color: text-primary;
    in property <color> warning-color: text-muted;
    callback clicked(string);
    callback menu-clicked(string);
    callback add-clicked(string);
    callback github-clicked(string);

    height: 34px;
    border-radius: 8px;
    border-width: project-focus.has-focus || entry.active || entry.error ? 1px : 0px;
    border-color: entry.error ? danger-color : project-focus.has-focus ? focus-ring : overlay-active;
    background: entry.active || project-touch.pressed ? overlay-active : project-touch.has-hover ? overlay-hover : transparent;

    project-focus := FocusScope {
        width: 0px;
        height: 0px;
        key-pressed(event) => {
            if event.text == "\n" || event.text == " " {
                root.clicked(root.entry.id);
                return accept;
            }
            return reject;
        }
    }

    project-touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            project-focus.focus();
            root.clicked(root.entry.id);
        }
    }

    AoAvatar {
        x: 8px;
        y: 5px;
        width: 24px;
        height: 24px;
        border-radius: 6px;
        label: entry.initials;
        accent: entry.accent;
        text-color: text-primary;
    }

    Text {
        x: 42px;
        y: 8px;
        width: parent.width - 154px;
        text: entry.loading ? "loading project..." : entry.error ? "project unavailable" : entry.name;
        color: entry.error ? danger-color : entry.loading ? warning-color : text-primary;
        font-family: "Lilex Nerd Font Mono";
        font-size: 13px;
        font-weight: 600;
    }

    if entry.task-count-label != "0": Text {
        x: parent.width - 54px;
        y: 9px;
        width: 18px;
        horizontal-alignment: center;
        text: entry.expanded ? "v" : ">";
        color: text-muted;
        font-family: "Lilex Nerd Font Mono";
        font-size: 10px;
        font-weight: 700;
    }

    if project-touch.has-hover || project-focus.has-focus: Rectangle {
        x: parent.width - 88px;
        y: 6px;
        width: 78px;
        height: 22px;
        border-radius: 7px;
        background: project-touch.has-hover ? overlay-hover : transparent;

        Text {
            x: 7px;
            y: 5px;
            text: "...";
            color: text-muted;
            font-family: "Lilex Nerd Font Mono";
            font-size: 10px;
            font-weight: 600;
        }

        menu-touch := TouchArea {
            x: 0px;
            y: 0px;
            width: 28px;
            height: parent.height;
            accessible-role: button;
            accessible-label: "Project menu for " + root.entry.name;
            clicked => {
                project-focus.focus();
                root.menu-clicked(root.entry.id);
            }
        }

        Text {
            x: 33px;
            y: 5px;
            text: "gh";
            color: text-muted;
            font-family: "Lilex Nerd Font Mono";
            font-size: 10px;
            font-weight: 600;
        }

        github-touch := TouchArea {
            x: 28px;
            y: 0px;
            width: 26px;
            height: parent.height;
            accessible-role: button;
            accessible-label: "Open repository for " + root.entry.name;
            clicked => {
                project-focus.focus();
                root.github-clicked(root.entry.id);
            }
        }

        Text {
            x: 61px;
            y: 4px;
            text: "+";
            color: text-muted;
            font-family: "Lilex Nerd Font Mono";
            font-size: 12px;
            font-weight: 700;
        }

        add-touch := TouchArea {
            x: 54px;
            y: 0px;
            width: 24px;
            height: parent.height;
            accessible-role: button;
            accessible-label: "New task for " + root.entry.name;
            clicked => {
                project-focus.focus();
                root.add-clicked(root.entry.id);
            }
        }
    }
}

export component AoSidebarTaskRow inherits Rectangle {
    in property <TaskSidebarEntry> entry;
    in property <color> overlay-hover;
    in property <color> overlay-active;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> text-secondary;
    in property <color> success-color;
    in property <color> row-border-color;
    in property <color> focus-ring: row-border-color;
    in property <color> danger-color: text-primary;
    in property <color> warning-color: text-secondary;
    callback clicked(string);
    callback menu-clicked(string);
    callback rename-clicked(string);
    callback delete-clicked(string);

    height: 44px;
    border-radius: 8px;
    border-width: entry.active || task-focus.has-focus || entry.error || entry.delete-confirm ? 1px : 0px;
    border-color: entry.delete-confirm || entry.error ? danger-color : task-focus.has-focus ? focus-ring : row-border-color;
    background: entry.active || task-touch.pressed ? overlay-active : task-touch.has-hover ? overlay-hover : transparent;

    task-focus := FocusScope {
        width: 0px;
        height: 0px;
        key-pressed(event) => {
            if event.text == "\n" || event.text == " " {
                root.clicked(root.entry.id);
                return accept;
            }
            return reject;
        }
    }

    task-touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            task-focus.focus();
            root.clicked(root.entry.id);
        }
    }

    Rectangle {
        x: 12px;
        y: 16px;
        width: 8px;
        height: 8px;
        border-radius: 4px;
        background: entry.running ? success-color : text-muted;
        opacity: entry.running ? 1.0 : 0.38;
    }

    Text {
        x: 28px;
        y: 6px;
        width: parent.width - 116px;
        text: entry.editing ? entry.title + " |" : entry.title;
        color: entry.error || entry.delete-confirm ? danger-color : text-primary;
        font-family: "Lilex Nerd Font Mono";
        font-size: 13px;
        font-weight: 600;
    }

    if entry.pinned: Text {
        x: parent.width - 82px;
        y: 7px;
        text: "pin";
        color: text-secondary;
        font-family: "Lilex Nerd Font Mono";
        font-size: 10px;
        font-weight: 600;
    }

    Text {
        x: 28px;
        y: 24px;
        width: parent.width - 64px;
        text: entry.loading ? "loading task..." : entry.error ? "task unavailable" : entry.delete-confirm ? "confirm delete" : entry.branch + (entry.metadata != "" ? " • " + entry.metadata : "");
        color: entry.error || entry.delete-confirm ? danger-color : entry.loading ? warning-color : text-muted;
        font-family: "Lilex Nerd Font Mono";
        font-size: 11px;
    }

    if task-touch.has-hover || task-focus.has-focus || entry.delete-confirm: Rectangle {
        x: parent.width - 86px;
        y: 21px;
        width: 76px;
        height: 20px;
        border-radius: 7px;
        background: entry.delete-confirm ? danger-color.with-alpha(0.18) : overlay-hover;

        Text {
            x: 8px;
            y: 5px;
            text: "ren";
            color: text-secondary;
            font-family: "Lilex Nerd Font Mono";
            font-size: 10px;
            font-weight: 600;
        }

        rename-touch := TouchArea {
            x: 0px;
            y: 0px;
            width: 30px;
            height: parent.height;
            accessible-role: button;
            accessible-label: "Rename task " + root.entry.title;
            clicked => {
                task-focus.focus();
                root.rename-clicked(root.entry.id);
            }
        }

        Text {
            x: 39px;
            y: 5px;
            text: entry.delete-confirm ? "del" : "...";
            color: entry.delete-confirm ? danger-color : text-secondary;
            font-family: "Lilex Nerd Font Mono";
            font-size: 10px;
            font-weight: 600;
        }

        menu-touch := TouchArea {
            x: 30px;
            y: 0px;
            width: 46px;
            height: parent.height;
            accessible-role: button;
            accessible-label: entry.delete-confirm ? "Confirm delete task " + root.entry.title : "Task menu for " + root.entry.title;
            clicked => {
                task-focus.focus();
                if root.entry.delete-confirm {
                    root.delete-clicked(root.entry.id);
                } else {
                    root.menu-clicked(root.entry.id);
                }
            }
        }
    }
}

export component AoSidebarProjectTreeRow inherits Rectangle {
