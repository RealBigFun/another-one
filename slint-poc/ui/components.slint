import { LineEdit } from "std-widgets.slint";

export struct ProjectSidebarEntry {
    id: string,
    name: string,
    path: string,
    branch: string,
    initials: string,
    accent: color,
    active: bool,
    task-count-label: string,
}

export struct TaskSidebarEntry {
    id: string,
    title: string,
    branch: string,
    metadata: string,
    initials: string,
    accent: color,
    active: bool,
    pinned: bool,
    running: bool,
}

export struct TerminalTabChip {
    id: string,
    title: string,
    provider: string,
    active: bool,
    running: bool,
    pinned: bool,
}

export struct MenuEntry {
    id: string,
    label: string,
    shortcut: string,
    selected: bool,
    disabled: bool,
    destructive: bool,
}

export component AoButton inherits Rectangle {
    in property <string> label;
    in property <string> control-label: label;
    in property <bool> active: false;
    in property <bool> disabled: false;
    in property <bool> loading: false;
    in property <bool> destructive: false;
    in property <color> bg;
    in property <color> hover-bg;
    in property <color> border;
    in property <color> text-color;
    in property <color> danger-color: text-color;
    callback clicked();

    height: 26px;
    accessible-role: button;
    accessible-label: control-label;
    border-radius: 8px;
    border-width: 1px;
    border-color: active ? border : transparent;
    opacity: disabled ? 0.45 : 1.0;
    background: active ? bg : touch.has-hover && !disabled ? hover-bg : transparent;

    touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            if !root.disabled {
                root.clicked();
            }
        }
    }

    Text {
        x: 10px;
        y: 6px;
        width: parent.width - 20px;
        text: loading ? "..." : label;
        color: destructive ? danger-color : text-color;
        font-family: "monospace";
        font-size: 12px;
        font-weight: 700;
    }
}

export component AoIconButton inherits Rectangle {
    in property <string> icon;
    in property <string> control-label;
    in property <bool> active: false;
    in property <bool> disabled: false;
    in property <color> bg;
    in property <color> hover-bg;
    in property <color> border;
    in property <color> icon-color;
    callback clicked();

    width: 30px;
    height: 26px;
    accessible-role: button;
    accessible-label: control-label;
    border-radius: 8px;
    border-width: active ? 1px : 0px;
    border-color: border;
    background: active ? bg : icon-touch.has-hover && !disabled ? hover-bg : transparent;
    opacity: disabled ? 0.42 : 1.0;

    icon-touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            if !root.disabled {
                root.clicked();
            }
        }
    }

    Text {
        x: 0px;
        y: 5px;
        width: parent.width;
        horizontal-alignment: center;
        text: icon;
        color: icon-color;
        font-family: "monospace";
        font-size: 13px;
        font-weight: 900;
    }
}

export component AoSplitButton inherits Rectangle {
    in property <string> label;
    in property <string> control-label: label;
    in property <string> menu-control-label: label + " menu";
    in property <bool> active: false;
    in property <bool> disabled: false;
    in property <color> bg;
    in property <color> hover-bg;
    in property <color> border;
    in property <color> text-color;
    callback clicked();
    callback menu-clicked();

    height: 26px;
    accessible-role: button;
    accessible-label: control-label;
    border-radius: 8px;
    border-width: 1px;
    border-color: border;
    background: active ? bg : split-touch.has-hover && !disabled ? hover-bg : transparent;
    opacity: disabled ? 0.45 : 1.0;

    split-touch := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width - 30px;
        height: parent.height;
        clicked => {
            if !root.disabled {
                root.clicked();
            }
        }
    }

    Rectangle {
        x: parent.width - 30px;
        y: 0px;
        width: 1px;
        height: parent.height;
        background: border;
        opacity: 0.6;
    }

    menu-touch := TouchArea {
        x: parent.width - 30px;
        y: 0px;
        width: 30px;
        height: parent.height;
        accessible-role: button;
        accessible-label: root.menu-control-label;
        clicked => {
            if !root.disabled {
                root.menu-clicked();
            }
        }
    }

    Text {
        x: 10px;
        y: 6px;
        width: parent.width - 44px;
        text: label;
        color: text-color;
        font-family: "monospace";
        font-size: 12px;
        font-weight: 800;
    }

    Text {
        x: parent.width - 24px;
        y: 6px;
        width: 18px;
        horizontal-alignment: center;
        text: "v";
        color: text-color;
        font-family: "monospace";
        font-size: 11px;
        font-weight: 900;
    }
}

export component AoStatusPill inherits Rectangle {
    in property <string> label;
    in property <string> kind: "neutral";
    in property <color> bg;
    in property <color> border;
    in property <color> text-color;
    in property <color> success-color: text-color;
    in property <color> warning-color: text-color;
    in property <color> danger-color: text-color;

    height: 24px;
    border-radius: 12px;
    border-width: 1px;
    border-color: border;
    background: bg;

    Text {
        x: 12px;
        y: 5px;
        width: parent.width - 24px;
        text: label;
        color: kind == "success" ? success-color : kind == "warning" ? warning-color : kind == "danger" ? danger-color : text-color;
        font-family: "monospace";
        font-size: 12px;
        font-weight: 700;
    }
}

export component AoResourceIndicator inherits Rectangle {
    in property <string> label;
    in property <color> bg;
    in property <color> border;
    in property <color> text-color;
    in property <color> warning-color;
    in property <color> danger-color;
    in property <bool> warning: false;
    in property <bool> danger: false;

    height: 24px;
    border-radius: 12px;
    border-width: 1px;
    border-color: danger ? danger-color : warning ? warning-color : border;
    background: bg;

    Text {
        x: 12px;
        y: 5px;
        width: parent.width - 24px;
        text: label;
        color: danger ? danger-color : warning ? warning-color : text-color;
        font-family: "monospace";
        font-size: 12px;
        font-weight: 800;
    }
}

export component AoSectionLabel inherits Text {
    in property <color> label-color;

    color: label-color;
    font-family: "monospace";
    font-size: 11px;
    font-weight: 800;
}

export component AoAvatar inherits Rectangle {
    in property <string> label;
    in property <color> accent;
    in property <color> text-color;

    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: accent;

    Text {
        x: 0px;
        y: 6px;
        width: parent.width;
        horizontal-alignment: center;
        text: label;
        color: text-color;
        font-family: "monospace";
        font-size: 12px;
        font-weight: 900;
    }
}

export component AoProjectRow inherits Rectangle {
    in property <ProjectSidebarEntry> entry;
    in property <color> overlay-hover;
    in property <color> overlay-active;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> text-secondary;
    callback clicked(string);

    height: 66px;
    border-radius: 11px;
    background: entry.active ? overlay-active : row-touch.has-hover ? overlay-hover : transparent;

    row-touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.clicked(root.entry.id);
        }
    }

    AoAvatar {
        x: 12px;
        y: 11px;
        label: entry.initials;
        accent: entry.accent;
        text-color: text-primary;
    }

    Text {
        x: 52px;
        y: 9px;
        width: parent.width - 104px;
        text: entry.name;
        color: text-primary;
        font-family: "monospace";
        font-size: 14px;
        font-weight: 800;
    }

    Text {
        x: 52px;
        y: 29px;
        width: parent.width - 74px;
        text: entry.branch;
        color: text-muted;
        font-family: "monospace";
        font-size: 11px;
    }

    Text {
        x: parent.width - 45px;
        y: 13px;
        width: 32px;
        horizontal-alignment: right;
        text: entry.task-count-label;
        color: text-secondary;
        font-family: "monospace";
        font-size: 11px;
        font-weight: 700;
    }

    Text {
        x: 52px;
        y: 46px;
        width: parent.width - 66px;
        text: entry.path;
        color: text-muted;
        font-family: "monospace";
        font-size: 10px;
    }
}

export component AoTaskRow inherits Rectangle {
    in property <TaskSidebarEntry> entry;
    in property <color> overlay-hover;
    in property <color> overlay-active;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> text-secondary;
    in property <color> success-color;
    in property <color> row-border-color;
    callback clicked(string);

    height: 58px;
    border-radius: 10px;
    background: entry.active ? overlay-active : row-touch.has-hover ? overlay-hover : transparent;
    border-width: entry.active ? 1px : 0px;
    border-color: row-border-color;

    row-touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.clicked(root.entry.id);
        }
    }

    AoAvatar {
        x: 12px;
        y: 15px;
        label: entry.initials;
        accent: entry.accent;
        text-color: text-primary;
    }

    Text {
        x: 52px;
        y: 10px;
        width: parent.width - 94px;
        text: entry.title;
        color: text-primary;
        font-family: "monospace";
        font-size: 13px;
        font-weight: 800;
    }

    Text {
        x: 52px;
        y: 30px;
        width: parent.width - 70px;
        text: entry.metadata;
        color: text-muted;
        font-family: "monospace";
        font-size: 11px;
    }

    if entry.pinned: Text {
        x: parent.width - 64px;
        y: 11px;
        text: "pin";
        color: text-secondary;
        font-family: "monospace";
        font-size: 10px;
        font-weight: 800;
    }

    Rectangle {
        x: parent.width - 22px;
        y: 18px;
        width: 8px;
        height: 8px;
        border-radius: 4px;
        background: entry.running ? success-color : text-muted;
        opacity: entry.running ? 1.0 : 0.36;
    }
}

export component AoTabChip inherits Rectangle {
    in property <TerminalTabChip> tab;
    in property <color> overlay-hover;
    in property <color> overlay-active;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> success-color;
    callback clicked(string);

    height: 30px;
    border-radius: 9px;
    background: tab.active ? overlay-active : chip-touch.has-hover ? overlay-hover : transparent;

    chip-touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.clicked(root.tab.id);
        }
    }

    Rectangle {
        x: 10px;
        y: 11px;
        width: 7px;
        height: 7px;
        border-radius: 4px;
        background: tab.running ? success-color : text-muted;
        opacity: tab.running ? 1.0 : 0.38;
    }

    Text {
        x: 24px;
        y: 7px;
        width: parent.width - 46px;
        text: tab.title;
        color: tab.active ? text-primary : text-muted;
        font-family: "monospace";
        font-size: 12px;
        font-weight: tab.active ? 800 : 600;
    }

    if tab.pinned: Text {
        x: parent.width - 22px;
        y: 8px;
        text: "*";
        color: text-primary;
        font-family: "monospace";
        font-size: 12px;
        font-weight: 900;
    }
}

export component AoCard inherits Rectangle {
    in property <string> title;
    in property <string> body;
    in property <color> card-bg;
    in property <color> card-border-color;
    in property <color> text-primary;
    in property <color> text-muted;

    height: 88px;
    border-radius: 12px;
    border-width: 1px;
    border-color: card-border-color;
    background: card-bg;

    Text {
        x: 14px;
        y: 12px;
        width: parent.width - 28px;
        text: title;
        color: text-primary;
        font-family: "monospace";
        font-size: 12px;
        font-weight: 800;
    }

    Text {
        x: 14px;
        y: 36px;
        width: parent.width - 28px;
        text: body;
        color: text-muted;
        font-family: "monospace";
        font-size: 11px;
    }
}

export component AoStateCard inherits Rectangle {
    in property <string> title;
    in property <string> body;
    in property <string> state: "populated";
    in property <string> action-label: "";
    in property <color> card-bg;
    in property <color> card-border-color;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> success-color;
    in property <color> warning-color;
    in property <color> danger-color;
    callback action-clicked();

    height: 104px;
    border-radius: 12px;
    border-width: 1px;
    border-color: state == "error" ? danger-color : state == "loading" ? warning-color : card-border-color;
    background: card-bg;

    Rectangle {
        x: 14px;
        y: 14px;
        width: 8px;
        height: 8px;
        border-radius: 4px;
        background: state == "error" ? danger-color : state == "loading" ? warning-color : state == "empty" ? text-muted : success-color;
        opacity: state == "empty" ? 0.42 : 1.0;
    }

    Text {
        x: 30px;
        y: 10px;
        width: parent.width - 44px;
        text: title;
        color: text-primary;
        font-family: "monospace";
        font-size: 12px;
        font-weight: 800;
    }

    Text {
        x: 14px;
        y: 36px;
        width: parent.width - 28px;
        text: state == "loading" ? "Loading..." : body;
        color: state == "error" ? danger-color : text-muted;
        font-family: "monospace";
        font-size: 11px;
    }

    if action-label != "": AoButton {
        x: 14px;
        y: parent.height - 34px;
        width: 96px;
        label: action-label;
        bg: root.card-bg;
        hover-bg: root.card-border-color;
        border: root.card-border-color;
        text-color: root.text-primary;
        active: false;
        clicked => {
            root.action-clicked();
        }
    }
}

export component AoTextInput inherits Rectangle {
    in property <string> placeholder-text;
    in-out property <string> text <=> input.text;
    in property <color> field-bg;
    in property <color> field-border;
    in property <color> focus-border: field-border;
    in property <color> error-color: field-border;
    in property <bool> error: false;
    in property <bool> disabled: false;

    height: 36px;
    border-radius: 9px;
    border-width: 1px;
    border-color: error ? error-color : input.has-focus ? focus-border : field-border;
    background: field-bg;
    opacity: disabled ? 0.52 : 1.0;

    input := LineEdit {
        x: 8px;
        y: 3px;
        width: parent.width - 16px;
        height: parent.height - 6px;
        enabled: !root.disabled;
        placeholder-text: root.placeholder-text;
    }
}

export component AoModalCard inherits Rectangle {
    in property <color> card-bg;
    in property <color> card-border-color;

    width: 440px;
    height: 260px;
    border-radius: 18px;
    background: card-bg;
    border-width: 1px;
    border-color: card-border-color;
}

export component AoMenuItem inherits Rectangle {
    in property <MenuEntry> entry;
    in property <color> overlay-hover;
    in property <color> overlay-active;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> danger-color;
    callback clicked(string);

    height: 30px;
    accessible-role: button;
    accessible-label: entry.label;
    border-radius: 8px;
    background: entry.selected ? overlay-active : item-touch.has-hover && !entry.disabled ? overlay-hover : transparent;
    opacity: entry.disabled ? 0.45 : 1.0;

    item-touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            if !root.entry.disabled {
                root.clicked(root.entry.id);
            }
        }
    }

    Text {
        x: 10px;
        y: 7px;
        width: parent.width - 92px;
        text: entry.label;
        color: entry.destructive ? danger-color : text-primary;
        font-family: "monospace";
        font-size: 12px;
        font-weight: entry.selected ? 800 : 600;
    }

    Text {
        x: parent.width - 78px;
        y: 8px;
        width: 66px;
        horizontal-alignment: right;
        text: entry.shortcut;
        color: text-muted;
        font-family: "monospace";
        font-size: 10px;
    }
}

export component AoMenu inherits Rectangle {
    in property <[MenuEntry]> entries;
    in property <color> card-bg;
    in property <color> menu-border-color;
    in property <color> overlay-hover;
    in property <color> overlay-active;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> danger-color;
    callback item-clicked(string);

    border-radius: 12px;
    border-width: 1px;
    border-color: menu-border-color;
    background: card-bg;

    for entry[index] in entries: AoMenuItem {
        x: 6px;
        y: 6px + index * 32px;
        width: parent.width - 12px;
        entry: entry;
        overlay-hover: root.overlay-hover;
        overlay-active: root.overlay-active;
        text-primary: root.text-primary;
        text-muted: root.text-muted;
        danger-color: root.danger-color;
        clicked(id) => {
            root.item-clicked(id);
        }
    }
}

export component AoTooltip inherits Rectangle {
    in property <string> message;
    in property <color> card-bg;
    in property <color> tooltip-border-color;
    in property <color> text-color;

    height: 28px;
    border-radius: 8px;
    border-width: 1px;
    border-color: tooltip-border-color;
    background: card-bg;

    Text {
        x: 10px;
        y: 7px;
        width: parent.width - 20px;
        text: message;
        color: text-color;
        font-family: "monospace";
        font-size: 11px;
        font-weight: 700;
    }
}

export component AoToast inherits Rectangle {
    in property <string> kind: "info";
    in property <string> message;
    in property <string> detail: "";
    in property <color> card-bg;
    in property <color> toast-border-color;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> success-color;
    in property <color> warning-color;
    in property <color> danger-color;
    callback dismissed();
    callback copy-requested();

    height: detail == "" ? 54px : 74px;
    border-radius: 14px;
    border-width: 1px;
    border-color: kind == "error" ? danger-color : kind == "warning" ? warning-color : kind == "success" ? success-color : toast-border-color;
    background: card-bg;

    Rectangle {
        x: 14px;
        y: 16px;
        width: 9px;
        height: 9px;
        border-radius: 5px;
        background: kind == "error" ? danger-color : kind == "warning" ? warning-color : kind == "success" ? success-color : text-muted;
    }

    Text {
        x: 32px;
        y: 10px;
        width: parent.width - 96px;
        text: message;
        color: text-primary;
        font-family: "monospace";
        font-size: 12px;
        font-weight: 800;
    }

    if detail != "": Text {
        x: 32px;
        y: 32px;
        width: parent.width - 96px;
        text: detail;
        color: kind == "error" ? danger-color : text-muted;
        font-family: "monospace";
        font-size: 11px;
    }

    AoIconButton {
        x: parent.width - 62px;
        y: 14px;
        icon: "C";
        control-label: "Copy notification details";
        bg: root.card-bg;
        hover-bg: root.toast-border-color;
        border: root.toast-border-color;
        icon-color: root.text-muted;
        clicked => {
            root.copy-requested();
        }
    }

    AoIconButton {
        x: parent.width - 30px;
        y: 14px;
        icon: "x";
        control-label: "Dismiss notification";
        bg: root.card-bg;
        hover-bg: root.toast-border-color;
        border: root.toast-border-color;
        icon-color: root.text-muted;
        clicked => {
            root.dismissed();
        }
    }
}
