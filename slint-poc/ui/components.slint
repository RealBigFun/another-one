    border-color: entry.error ? danger-color : project-focus.has-focus ? focus-ring : active-border;
    background: entry.active || project-touch.pressed ? overlay-active : project-touch.has-hover ? overlay-hover : transparent;

    project-focus := FocusScope {
        width: 0px;
        height: 0px;
        key-pressed(event) => {
            if event.text == "\n" || event.text == " " {
                root.clicked(root.entry.project-id);
                return accept;
            }
            return reject;
        }
    }

    project-touch := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            project-focus.focus();
            root.clicked(root.entry.project-id);
        }
    }

    AoAvatar {
        x: 8px;
        y: 5px;
        width: 24px;
        height: 24px;
        border-radius: 6px;
        label: entry.initials;
        accent: entry.accent;
        text-color: text-primary;
    }

    Text {
        x: 42px;
        y: 8px;
        width: parent.width - 154px;
        text: entry.loading ? "loading project..." : entry.error ? "project unavailable" : entry.name;
        color: entry.error ? danger-color : entry.loading ? warning-color : text-primary;
        font-family: "Lilex Nerd Font Mono";
        font-size: 13px;
        font-weight: 600;
    }

    if entry.has-children: Rectangle {
        x: parent.width - 106px;
        y: 9px;
        width: 18px;
        height: 18px;
        background: transparent;

        Image {
            x: 3px;
            y: 2px;
            width: 12px;
            height: 12px;
            source: entry.expanded ? @image-url("../../desktop/assets/icons/icons__chevron-down.svg") : @image-url("../../desktop/assets/icons/icons__chevron-right.svg");
            colorize: icon-color;
        }
    }

    if project-touch.has-hover || project-focus.has-focus: Rectangle {
        x: parent.width - 84px;
        y: 6px;
        width: 24px;
        height: 22px;
        border-radius: 7px;
        background: overlay-hover;

        Image {
            x: 5px;
            y: 4px;
            width: 14px;
            height: 14px;
            source: @image-url("../../desktop/assets/icons/icons__ellipsis.svg");
            colorize: icon-color;
        }

        menu-touch := TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            accessible-role: button;
            accessible-label: "Project menu for " + root.entry.name;
            clicked => {
                project-focus.focus();
                root.menu-clicked(root.entry.project-id);
            }
        }
    }

    if entry.github-url != "": Rectangle {
        x: parent.width - 58px;
        y: 6px;
        width: 24px;
        height: 22px;
        border-radius: 7px;
        background: github-touch.has-hover ? overlay-hover : transparent;

        Image {
            x: 5px;
            y: 4px;
            width: 14px;
            height: 14px;
            source: @image-url("../../desktop/assets/icons/icons__github.svg");
            colorize: icon-color;
        }

        github-touch := TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            accessible-role: button;
            accessible-label: "Open GitHub for " + root.entry.name;
            clicked => {
                project-focus.focus();
                root.github-clicked(root.entry.github-url);
            }
        }
    }

    Rectangle {
        x: parent.width - 32px;
        y: 6px;
        width: 24px;
        height: 22px;
        border-radius: 7px;
        background: add-touch.has-hover ? overlay-hover : transparent;

        Image {
            x: 5px;
            y: 4px;
            width: 14px;
            height: 14px;
            source: @image-url("../../desktop/assets/icons/icons__plus.svg");
            colorize: icon-color;
        }

        add-touch := TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            accessible-role: button;
            accessible-label: "New task for " + root.entry.name;
            clicked => {
                project-focus.focus();
                root.add-clicked(root.entry.project-id);
            }
        }
    }
}

