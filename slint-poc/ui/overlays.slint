import {
    AoAssetIconButton,
    AoButton,
    AoMenu,
    AoModalCard,
    AoStateCard,
    AoTextInput,
    MenuEntry,
} from "components.slint";

component AoResourceMetricCard inherits Rectangle {
    in property <string> title;
    in property <string> value;
    in property <color> card-bg;
    in property <color> card-border-color;
    in property <color> text-primary;
    in property <color> text-muted;

    height: 64px;
    border-radius: 12px;
    border-width: 1px;
    border-color: card-border-color;
    background: card-bg;

    Text {
        x: 10px;
        y: 10px;
        width: parent.width - 20px;
        text: title;
        color: text-muted;
        font-family: "Lilex Nerd Font Mono";
        font-size: 10px;
        font-weight: 700;
    }

    Text {
        x: 10px;
        y: 32px;
        width: parent.width - 20px;
        text: value;
        color: text-primary;
        font-family: "Lilex Nerd Font Mono";
        font-size: 13px;
        font-weight: 700;
    }
}

export component AoMenuPopover inherits Rectangle {
    in property <length> menu-x;
    in property <length> menu-y;
    in property <length> menu-width: 260px;
    in property <length> menu-height: 136px;
    in property <bool> dismisses-on-outside-click: true;
    in property <[MenuEntry]> entries;
    in property <color> card-bg;
    in property <color> overlay-border-color;
    in property <color> overlay-hover;
    in property <color> overlay-active;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> danger-color;
    in property <color> focus-ring;
    callback dismissed();
    callback item-selected(string);

    background: transparent;

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            if root.dismisses-on-outside-click {
                root.dismissed();
            }
        }
    }

    AoMenu {
        x: root.menu-x;
        y: root.menu-y;
        width: root.menu-width;
        height: root.menu-height;
        entries: root.entries;
        card-bg: root.card-bg;
        menu-border-color: root.overlay-border-color;
        overlay-hover: root.overlay-hover;
        overlay-active: root.overlay-active;
        text-primary: root.text-primary;
        text-muted: root.text-muted;
        danger-color: root.danger-color;
        focus-ring: root.focus-ring;
        item-clicked(id) => {
            root.item-selected(id);
        }
    }
}

export component AoResourcePopover inherits Rectangle {
    in property <string> summary;
    in property <string> app-cpu-label: "tracked";
    in property <string> app-memory-label: root.summary;
    in property <string> session-count-label: "--";
    in property <string> terminal-sessions-state: "empty";
    in property <string> terminal-sessions-summary: "No active terminal sessions";
    in property <color> card-bg;
    in property <color> terminal-bg;
    in property <color> overlay-border-color;
    in property <color> text-primary;
    in property <color> text-muted;
    in property <color> success-color;
    in property <color> warning-color;
    in property <color> danger-color;
    callback refresh-requested();

    width: 360px;
    height: 296px;
    border-radius: 16px;
    border-width: 1px;
    border-color: root.overlay-border-color;
    background: root.card-bg;

    Text {
        x: 18px;
        y: 16px;
        text: "RESOURCE USAGE";
        color: root.text-muted;
        font-family: "Lilex Nerd Font Mono";
        font-size: 11px;
        font-weight: 600;
    }

    AoAssetIconButton {
        x: parent.width - 44px;
        y: 12px;
        width: 28px;
        icon-source: @image-url("../../desktop/assets/icons/icons__refresh.svg");
        control-label: "Refresh resource usage";
        bg: root.card-bg;
        hover-bg: root.overlay-border-color;
        border: root.overlay-border-color;
        icon-color: root.text-muted;
        clicked => {
            root.refresh-requested();
        }
    }

    Text {
        x: 16px;
        y: 52px;
        width: parent.width - 32px;
        text: "APP SHELL";
        color: root.text-primary;
        font-family: "Lilex Nerd Font Mono";
        font-size: 13px;
        font-weight: 700;
    }

    AoResourceMetricCard {
        x: 16px;
        y: 78px;
        width: (parent.width - 44px) / 3;
        title: "APP CPU";
        value: root.app-cpu-label;
        card-bg: root.terminal-bg;
        card-border-color: root.overlay-border-color;
        text-primary: root.text-primary;
        text-muted: root.text-muted;
    }

    AoResourceMetricCard {
        x: 22px + (parent.width - 44px) / 3;
        y: 78px;
        width: (parent.width - 44px) / 3;
        title: "APP MEM";
        value: root.app-memory-label;
        card-bg: root.terminal-bg;
        card-border-color: root.overlay-border-color;
        text-primary: root.text-primary;
        text-muted: root.text-muted;
    }

    AoResourceMetricCard {
        x: 28px + 2 * (parent.width - 44px) / 3;
        y: 78px;
        width: (parent.width - 44px) / 3;
        title: "SESSIONS";
        value: root.session-count-label;
        card-bg: root.terminal-bg;
        card-border-color: root.overlay-border-color;
        text-primary: root.text-primary;
        text-muted: root.text-muted;
    }

    Text {
        x: 16px;
        y: 160px;
        width: parent.width - 32px;
        text: "TERMINAL SESSIONS";
        color: root.text-primary;
        font-family: "Lilex Nerd Font Mono";
        font-size: 13px;
        font-weight: 700;
    }

    AoStateCard {
        x: 16px;
        y: 186px;
        width: parent.width - 32px;
        title: "Session tree";
        body: root.terminal-sessions-summary;
        state: root.terminal-sessions-state;
        action-label: "Refresh";
        card-bg: root.terminal-bg;
        card-border-color: root.overlay-border-color;
        text-primary: root.text-primary;
        text-muted: root.text-muted;
        success-color: root.success-color;
        warning-color: root.warning-color;
        danger-color: root.danger-color;
        action-clicked => {
            root.refresh-requested();
        }
    }
}

export component AoNewTaskModal inherits Rectangle {
    in-out property <string> task-name;
    in-out property <string> branch-name;
    in property <string> project-id;
    in property <color> card-bg;
    in property <color> terminal-bg;
    in property <color> overlay-active;
    in property <color> overlay-hover;
    in property <color> overlay-border-color;
    in property <color> focus-ring;
    in property <color> text-primary;
    in property <color> text-secondary;
    in property <color> text-muted;
    in property <color> danger-color;
    in property <bool> submitting: false;
    in property <string> validation-message: root.task-name == "" ? "Task name is required." : "";
    in property <string> status-message: root.submitting ? "Creating task..." : root.validation-message != "" ? root.validation-message : "Enter creates the task. Escape closes the modal.";
    callback dismissed();
    callback submitted(string, string, string);

    background: #00000080;
    property <length> modal-width: min(440px, root.width - 32px);
    property <length> modal-height: 286px;
    property <bool> can-submit: root.task-name != "" && !root.submitting;

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.dismissed();
        }
    }

    AoModalCard {
        x: (parent.width - root.modal-width) / 2;
        y: (parent.height - root.modal-height) / 2;
        width: root.modal-width;
        height: root.modal-height;
        card-bg: root.card-bg;
        card-border-color: root.focus-ring;

        TouchArea {
            width: parent.width;
            height: parent.height;
        }

        Text {
            x: 24px;
            y: 22px;
            text: "New task";
            color: root.text-primary;
            font-family: "Lilex Nerd Font Mono";
            font-size: 20px;
            font-weight: 700;
        }

        AoAssetIconButton {
            x: parent.width - 50px;
            y: 20px;
            width: 30px;
            icon-source: @image-url("../../desktop/assets/icons/icons__close.svg");
            control-label: "Close new task modal";
            bg: root.overlay-active;
            hover-bg: root.overlay-hover;
            border: root.overlay-border-color;
            icon-color: root.text-secondary;
            clicked => {
                root.dismissed();
            }
        }

        Text {
            x: 24px;
            y: 56px;
            text: "Create a task/worktree from the active project context.";
            color: root.text-muted;
            font-family: "Lilex Nerd Font Mono";
            font-size: 12px;
        }

        AoTextInput {
            x: 24px;
            y: 92px;
            width: parent.width - 48px;
            placeholder-text: "Task name";
            text <=> root.task-name;
            field-bg: root.terminal-bg;
            field-border: root.overlay-border-color;
            focus-border: root.focus-ring;
            error-color: root.danger-color;
            text-color: root.text-primary;
            placeholder-color: root.text-muted;
            error: root.task-name == "";
        }

        AoTextInput {
            x: 24px;
            y: 142px;
            width: parent.width - 48px;
            placeholder-text: "Branch name";
            text <=> root.branch-name;
            field-bg: root.terminal-bg;
            field-border: root.overlay-border-color;
            focus-border: root.focus-ring;
            error-color: root.danger-color;
            text-color: root.text-primary;
            placeholder-color: root.text-muted;
        }

        Text {
            x: 24px;
            y: 184px;
            width: parent.width - 48px;
            text: root.status-message;
            color: root.validation-message != "" ? root.danger-color : root.text-muted;
            font-family: "Lilex Nerd Font Mono";
            font-size: 11px;
            font-weight: root.validation-message != "" ? 700 : 500;
        }

        AoButton {
            x: parent.width - 238px;
            y: 224px;
            width: 102px;
            label: "Cancel";
            disabled: root.submitting;
            active: false;
            bg: root.overlay-active;
            hover-bg: root.overlay-hover;
            border: root.overlay-border-color;
            text-color: root.text-secondary;
            clicked => {
                root.dismissed();
            }
        }

        AoButton {
            x: parent.width - 126px;
            y: 224px;
            width: 102px;
            label: root.submitting ? "Creating" : "Create";
            active: true;
            disabled: !root.can-submit;
            bg: root.overlay-active;
            hover-bg: root.overlay-hover;
            border: root.overlay-border-color;
            text-color: root.text-primary;
            clicked => {
                root.submitted(root.task-name, root.branch-name, root.project-id);
            }
        }
    }
}

export component AoActionModal inherits Rectangle {
    in property <string> title: "Add Action";
    in-out property <string> action-name;
    in-out property <string> action-command;
    in property <color> card-bg;
    in property <color> terminal-bg;
    in property <color> overlay-active;
    in property <color> overlay-hover;
    in property <color> overlay-border-color;
    in property <color> focus-ring;
    in property <color> text-primary;
    in property <color> text-secondary;
    in property <color> text-muted;
    in property <color> danger-color;
    in property <string> action-kind: "shell";
    in property <bool> submitting: false;
    in property <string> validation-message: root.action-name == "" ? "Custom actions need a name." : root.action-kind == "shell" && root.action-command == "" ? "Shell actions need a command." : "";
    in property <string> status-message: root.validation-message != "" ? root.validation-message : "Command+Enter saves in GPUI. Escape closes; dropdowns close first.";
    callback dismissed();
    callback saved(string, string);

    background: #00000080;
    property <length> modal-width: min(520px, root.width - 32px);
    property <length> modal-height: 342px;
    property <bool> can-save: root.validation-message == "" && !root.submitting;

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            root.dismissed();
        }
    }

    AoModalCard {
        x: (parent.width - root.modal-width) / 2;
        y: (parent.height - root.modal-height) / 2;
        width: root.modal-width;
        height: root.modal-height;
        card-bg: root.card-bg;
        card-border-color: root.focus-ring;

        TouchArea {
            width: parent.width;
            height: parent.height;
        }

        Text {
            x: 24px;
            y: 22px;
            text: root.title;
            color: root.text-primary;
            font-family: "Lilex Nerd Font Mono";
            font-size: 20px;
            font-weight: 700;
        }

        AoAssetIconButton {
            x: parent.width - 50px;
            y: 20px;
            width: 30px;
            icon-source: @image-url("../../desktop/assets/icons/icons__close.svg");
            control-label: "Close action modal";
            bg: root.overlay-active;
            hover-bg: root.overlay-hover;
            border: root.overlay-border-color;
            icon-color: root.text-secondary;
            clicked => {
                root.dismissed();
            }
        }

        Text {
            x: 24px;
            y: 58px;
            text: "Configure the action label and shell command.";
            color: root.text-muted;
            font-family: "Lilex Nerd Font Mono";
            font-size: 12px;
        }

        AoTextInput {
            x: 24px;
            y: 98px;
            width: parent.width - 48px;
            placeholder-text: "Action name";
            text <=> root.action-name;
            field-bg: root.terminal-bg;
            field-border: root.overlay-border-color;
            focus-border: root.focus-ring;
            error-color: root.danger-color;
            text-color: root.text-primary;
            placeholder-color: root.text-muted;
            error: root.action-name == "";
        }

        AoTextInput {
            x: 24px;
            y: 148px;
            width: parent.width - 48px;
            placeholder-text: "Command";
            text <=> root.action-command;
            field-bg: root.terminal-bg;
            field-border: root.overlay-border-color;
            focus-border: root.focus-ring;
            error-color: root.danger-color;
            text-color: root.text-primary;
            placeholder-color: root.text-muted;
        }

        Text {
            x: 24px;
            y: 196px;
            width: parent.width - 48px;
            text: root.status-message;
            color: root.validation-message != "" ? root.danger-color : root.text-muted;
            font-family: "Lilex Nerd Font Mono";
            font-size: 11px;
            font-weight: root.validation-message != "" ? 700 : 500;
        }

        AoButton {
            x: parent.width - 238px;
            y: 280px;
            width: 102px;
            label: "Cancel";
            disabled: root.submitting;
            active: false;
            bg: root.overlay-active;
            hover-bg: root.overlay-hover;
            border: root.overlay-border-color;
            text-color: root.text-secondary;
            clicked => {
                root.dismissed();
            }
        }

        AoButton {
            x: parent.width - 126px;
            y: 280px;
            width: 102px;
            label: root.submitting ? "Saving" : "Save";
            active: true;
            disabled: !root.can-save;
            bg: root.overlay-active;
            hover-bg: root.overlay-hover;
            border: root.overlay-border-color;
            text-color: root.text-primary;
            clicked => {
                root.saved(root.action-name, root.action-command);
            }
        }
    }
}
